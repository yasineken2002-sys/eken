// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  organizationId      String
  email               String    @unique
  // Nullable: vid invite skapas User utan lösenord. Lösenord sätts först
  // när inbjudan accepteras via /v1/auth/accept-invite. login() avvisar
  // användare där passwordHash är null (samma "Felaktiga inloggningsuppgifter"
  // som ett felaktigt lösenord — ingen enumeration).
  passwordHash        String?
  firstName           String
  lastName            String
  role                UserRole  @default(VIEWER)
  avatarUrl           String?
  isActive            Boolean   @default(true)
  mustChangePassword  Boolean   @default(false)
  lastLoginAt         DateTime?
  // Brute-force-skydd: räknar upp vid felaktigt lösenord, nollställs vid
  // lyckad inloggning. När loginAttempts ≥ 10 sätts lockedUntil 15 min
  // framåt och inga försök släpps förrän klockan passerat.
  loginAttempts       Int       @default(0)
  lockedUntil         DateTime?

  // ─── Acceptans av juridiska dokument ───────────────────────────────────
  // Sätts när användaren bockat i "Jag accepterar Användarvillkor och
  // Integritetspolicy" vid registrering. termsVersion snapshot:as från
  // CURRENT_TERMS_VERSION i @eken/shared så att vi kan se exakt vilken
  // version användaren godkänt. Båda fälten är nullable för befintliga
  // konton — vid nästa inloggning visas re-acceptance-modalen om
  // versionen är lägre än CURRENT_TERMS_VERSION.
  acceptedTermsAt     DateTime?
  termsVersion        String?

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  invitations         UserInvitation[]
  journalEntries      JournalEntry[]
  closedPeriods       ClosedAccountingPeriod[]
  documents           Document[]
  importJobs          ImportJob[]
  aiConversations     AiConversation[]
  aiMemories          AiMemory[]
  aiUsageLogs         AiUsageLog[]
  aiToolExecutions    AiToolExecution[]
  notifications       Notification[]
  newsPosts           NewsPost[]
  sentMessages        SentMessage[]
  impersonationLogs   ImpersonationLog[]   @relation("ImpersonationTargetUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
}

// One-time-use tokens för glömt-lösenord-flödet. Cascade så att tokens
// försvinner om användaren raderas. usedAt sätts vid förbrukning för att
// förhindra återanvändning.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// One-time-use tokens för "bjud in användare"-flödet. När en OWNER/ADMIN
// bjuder in skapas både User (isActive=false) och en UserInvitation som
// pekar på det skapade kontot. Mottagaren accepterar via token.
model UserInvitation {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ─── Property (Fastighet) ─────────────────────────────────────────────────────

model Property {
  id                  String       @id @default(uuid())
  organizationId      String
  name                String
  propertyDesignation String
  type                PropertyType
  street              String
  city                String
  postalCode          String
  country             String       @default("SE")
  totalArea           Decimal      @db.Decimal(10, 2)
  yearBuilt           Int?

  // Information som genererade hyreskontrakt refererar till per fastighet —
  // hyresvärden fyller i en gång och slipper upprepa per kontrakt.
  fireSafetyNotes      String?
  commonAreasNotes     String?
  garbageDisposalRules String?

  // ── Förbrukningsdebitering (IMD) ──────────────────────────────────────────
  // Standard-leveranssätt för el/vatten/värme för fastighetens enheter. Kan
  // åsidosättas per lease (Lease.consumptionBillingMode). Default RENT_NOTICE_LINE
  // (det momssäkra fallet — rad på hyresavin).
  consumptionBillingMode ConsumptionBillingMode @default(RENT_NOTICE_LINE)

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  units              Unit[]
  documents          Document[]
  maintenanceTickets MaintenanceTicket[]
  inspections        Inspection[]
  maintenancePlans   MaintenancePlan[]
  newsPosts          NewsPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// ─── Unit (Lägenhet/Lokal) ────────────────────────────────────────────────────

model Unit {
  id          String     @id @default(uuid())
  propertyId  String
  name        String
  unitNumber  String
  type        UnitType
  status      UnitStatus @default(VACANT)
  area        Decimal    @db.Decimal(10, 2)
  floor       Int?
  rooms       Int?
  monthlyRent Decimal    @db.Decimal(10, 2)

  // Tilläggsutrustning som syns i kontrakts-PDF:n.
  hasBalcony         Boolean @default(false)
  hasStorage         Boolean @default(false)
  storageNumber      String?
  parkingSpaceNumber String?

  // Frivillig skattskyldighet för moms (ML 9 kap). Endast relevant för lokaler
  // (OFFICE/RETAIL/STORAGE/OTHER) som hyrs ut till momspliktig verksamhet — då
  // läggs 25% moms på hyran. Bostäder (APARTMENT) är ALLTID undantagna moms
  // (ML 3 kap 2 §) oavsett detta fält. Parkering är momspliktig enligt lag
  // (ML 3 kap 3 § 5) oberoende av frivillig skattskyldighet.
  voluntaryTaxLiability Boolean @default(false)

  property           Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases             Lease[]
  documents          Document[]
  maintenanceTickets MaintenanceTicket[]
  inspections        Inspection[]
  keyHandovers       KeyHandover[]
  meters             Meter[]
  contractImportRows ContractImportRow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propertyId, unitNumber])
  @@index([propertyId])
  @@index([status])
}

// ─── Tenant (Hyresgäst) ───────────────────────────────────────────────────────

model Tenant {
  id             String     @id @default(uuid())
  organizationId String
  type           TenantType
  firstName      String?
  lastName       String?
  personalNumber String?
  companyName    String?
  orgNumber      String?
  contactPerson  String?
  email          String
  phone          String?
  street         String?
  city           String?
  postalCode     String?
  country        String?    @default("SE")

  ocrNumber String? @unique

  // ─── Portal-aktivering & lösenordsautentisering ─────────────────────────────
  // portalActivated sätts när hyresgästen genomfört aktiveringsflödet
  // (signerat kontraktet och valt lösenord). passwordHash = bcryptjs (12 rounds).
  //
  // Aktivering och lösenordsåterställning är två separata flöden — en hyresgäst
  // som har ett pågående reset får inte sitt aktiveringstoken överskrivet (och
  // tvärtom). Båda kolumnerna lagrar SHA-256-hash av råtoken, aldrig klartext;
  // råtoken skickas bara i mejlet och kan inte återskapas från DB om den läcker.
  portalActivated              Boolean   @default(false)
  portalActivatedAt            DateTime?
  passwordHash                 String?
  activationTokenHash          String?   @unique
  activationTokenExpiresAt     DateTime?
  activationReminderSentAt     DateTime?
  passwordResetTokenHash       String?   @unique
  passwordResetTokenExpiresAt  DateTime?

  // ─── Portal-inbjudan (massutskick) ───────────────────────────────────────
  // Spårar massinbjudan till portalen separat från aktiveringstoken ovan.
  // invitedAt sätts när en inbjudan köas; inviteCount ökar vid varje (om)skick.
  // Statusen (ej inbjuden/inbjuden/levererad/studsad/aktiverad/saknar mejl)
  // HÄRLEDS i läs-endpointen — portalActivated är fortsatt auktoritativ för
  // aktivering.
  //
  // Leverans-/bounce-/spam-fälten fylls av Resend-webhooken (PR 2) och
  // nollställs vid varje (om)skick i sendOne() så att statusen speglar det
  // SENASTE utskicket, inte ett gammalt event.
  //
  // lastInviteMessageId är Resends message-id (email_id) för det senaste
  // utskicket och är webhookens ENDA korrelationsnyckel mot rätt hyresgäst.
  // @unique gör korrelationen entydig på DB-nivå: ett event kan aldrig träffa
  // mer än en hyresgäst. Sätts av mail-workern EFTER lyckad Resend-send
  // (id:t finns inte vid enqueue), inte här.
  invitedAt           DateTime?
  inviteCount         Int       @default(0)
  inviteDeliveredAt   DateTime?
  inviteBouncedAt     DateTime?
  inviteBounceReason  String?
  inviteComplainedAt  DateTime?
  lastInviteMessageId String?   @unique

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leases             Lease[]
  invoices           Invoice[]
  documents          Document[]
  signedDocuments    Document[]          @relation("DocumentSignedByTenant")
  maintenanceTickets MaintenanceTicket[]
  rentNotices        RentNotice[]
  inspections        Inspection[]
  magicLinks         TenantMagicLink[]
  sessions           TenantSession[]
  sentMessages       SentMessage[]
  deposits           Deposit[]
  aiConversations    AiTenantConversation[]
  aiUsageLogs        AiUsageLog[]
  aiToolExecutions   AiToolExecution[]
  terminationRequests TerminationRequest[]
  keyHandovers       KeyHandover[]
  consumptionCharges ConsumptionCharge[]
  miscCharges        MiscCharge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
}

// ─── Customer (Externt kundregister, separerat från Tenant) ───────────────────
// För fakturering av icke-hyresgäster: städfirmor, mäklare, engångsleverantörer
// etc. Customer kan inte logga in i tenant-portalen och har inga kontrakt.

model Customer {
  id             String       @id @default(uuid())
  organizationId String
  type           CustomerType

  firstName      String?
  lastName       String?
  personalNumber String?
  companyName    String?
  orgNumber      String?
  contactPerson  String?

  email          String?
  phone          String?

  street         String?
  city           String?
  postalCode     String?
  country        String?      @default("SE")

  reference      String?
  notes          String?
  isActive       Boolean      @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

// ─── Lease (Hyresavtal) ───────────────────────────────────────────────────────

model Lease {
  id                   String      @id @default(uuid())
  organizationId       String
  unitId               String
  tenantId             String
  status               LeaseStatus @default(DRAFT)
  leaseType            LeaseType   @default(INDEFINITE)
  renewalPeriodMonths  Int? // Bara meningsfullt för FIXED_TERM
  startDate            DateTime    @db.Date
  endDate              DateTime?   @db.Date
  monthlyRent          Decimal     @db.Decimal(10, 2)
  // Anger att monthlyRent är avtalad EXKLUSIVE moms (netto). Moms läggs på
  // hyresavin endast när detta är true OCH enheten är momspliktig
  // (voluntaryTaxLiability/parkering). Default false skyddar mot oavtalad
  // hyreshöjning (JB 12 kap 19 § 3 st) — moms läggs aldrig ovanpå en hyra som
  // kan ha avtalats inkl. moms. Sätts vid kontraktsregistrering för lokaler.
  monthlyRentExcludingVat Boolean  @default(false)
  depositAmount        Decimal     @db.Decimal(10, 2)
  noticePeriodMonths   Int         @default(3)
  // Regelverk för uppsägningstider (#69). Kolumn-default TENANCY_ACT (säker
  // fallback); create() sätter PRIVATE_RENTAL för bostad. Migration bakåtfyller
  // befintliga APARTMENT-kontrakt till PRIVATE_RENTAL.
  tenancyRegime        TenancyRegime @default(TENANCY_ACT)
  // Behålls för bakåtkompatibilitet (gamla rader). Nya kontrakt sätter
  // indexClauseType — `indexClause` speglar då (type !== NONE).
  indexClause          Boolean     @default(false)
  // Tidpunkt då avtalet AKTIVERADES (status → ACTIVE). Hette tidigare `signedAt`,
  // men fältet sätts vid admin-aktivering UTAN någon signatur — namnet "signerat"
  // var missvisande och bevisade inget om en underskrift. Döpt om till activatedAt
  // (S2). En faktisk BankID-signatur bevisas separat av SignatureEvidence (S1).
  activatedAt          DateTime?
  terminatedAt         DateTime?
  terminationReason    String?

  // ── Vad ingår i hyran ────────────────────────────────────────────────────
  // Branschpraxis: bostäder har normalt värme, vatten, varmvatten och
  // tvättstuga inkluderade; hushållsel och internet betalar hyresgästen.
  includesHeating       Boolean @default(true)
  includesWater         Boolean @default(true)
  includesHotWater      Boolean @default(true)
  includesElectricity   Boolean @default(false)
  includesInternet      Boolean @default(false)
  includesCleaning      Boolean @default(false)
  includesParking       Boolean @default(false)
  includesStorage       Boolean @default(false)
  includesLaundry       Boolean @default(true)

  // ── Tilläggshyror utöver grundhyran ──────────────────────────────────────
  parkingFee Decimal? @db.Decimal(10, 2)
  storageFee Decimal? @db.Decimal(10, 2)
  garageFee  Decimal? @db.Decimal(10, 2)

  // ── Användningsändamål (kritiskt för lokal — styr besittningsskydd) ─────
  usagePurpose String?

  // ── Husdjur ─────────────────────────────────────────────────────────────
  petsAllowed       PetPolicy @default(REQUIRES_APPROVAL)
  petsApprovalNotes String?

  // ── Andrahandsuthyrning ─────────────────────────────────────────────────
  sublettingAllowed Boolean @default(false)

  // ── Indexklausul ────────────────────────────────────────────────────────
  // Allt valfritt — hyresvärden fyller i det som är aktuellt. Kontrolltyp
  // styr vilken text som visas i kontraktet (KPI/förhandlat/marknadshyra).
  indexClauseType     IndexClauseType @default(NONE)
  indexBaseYear       Int?
  indexAdjustmentDate String? // "01-01" eller "anniversary"
  indexMaxIncrease    Decimal? @db.Decimal(5, 2)
  indexMinIncrease    Decimal? @db.Decimal(5, 2)
  indexNotes          String?

  // ── Försäkring ──────────────────────────────────────────────────────────
  requiresHomeInsurance Boolean @default(true)

  // ── Särskilda bestämmelser (Kontraktsmall 2.0) ──────────────────────────
  // Fritextfält där hyresvärden kan lägga till egna villkor som inte täcks
  // av standardparagraferna — t.ex. "tillträde först efter städning av
  // föregående hyresgäst" eller "garageplats nr 5 ingår". Renderas som
  // egen § "ÖVRIGA VILLKOR & SÄRSKILDA BESTÄMMELSER" i PDF:en när satt.
  specialTerms String? @db.Text

  // ── Kontraktsnummer (Kontraktsmall 2.0) ─────────────────────────────────
  // Fortlöpande nummer per organisation, format KONT-{år}-{löpnr:5}.
  // Genereras vid DRAFT → ACTIVE via ContractNumberSequence-tabellen.
  // Null så länge kontraktet är i DRAFT. Unikt PER ORGANISATION (se
  // @@unique nedan) — INTE globalt: ContractNumberSequence räknar per org+år,
  // så två organisationer delar oundvikligen samma löpnummer (KONT-2026-00001).
  contractNumber String?

  // ── Förbrukningsdebitering (IMD) ──────────────────────────────────────────
  // Åsidosätter fastighetens default (Property.consumptionBillingMode) för just
  // detta hyresförhållande. Null = ärv fastighetens inställning.
  consumptionBillingMode ConsumptionBillingMode?

  unit                Unit                 @relation(fields: [unitId], references: [id])
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  invoices            Invoice[]
  documents           Document[]
  rentNotices         RentNotice[]
  inspections         Inspection[]
  deposit             Deposit?
  rentIncreases       RentIncrease[]
  terminationRequests TerminationRequest[]
  keyHandovers        KeyHandover[]
  consumptionCharges  ConsumptionCharge[]
  miscCharges         MiscCharge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // OBS: Det finns även ett partial unique index lease_unit_active_unique
  // ON "Lease" ("unitId") WHERE status = 'ACTIVE' — definierat i migration
  // 20260426120000_lease_active_unique. Prisma stöder inte WHERE-villkor i
  // schemat så det måste hållas i sync manuellt.

  // Kontraktsnummer är unikt inom en organisation (numret tilldelas från en
  // per-org-sekvens). Tidigare globalt @unique gav P2002-kollision mellan
  // organisationer som nådde samma löpnummer. NULL (DRAFT) räknas inte som
  // dubblett i Postgres.
  @@unique([organizationId, contractNumber])
  @@index([organizationId])
  @@index([unitId])
  @@index([tenantId])
  @@index([status])
}

// ─── Invoice (Faktura) ────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  organizationId String
  invoiceNumber  String
  type           InvoiceType
  status         InvoiceStatus @default(DRAFT)
  tenantId       String?
  customerId     String?
  leaseId        String?
  subtotal       Decimal       @db.Decimal(10, 2)
  vatTotal       Decimal       @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  dueDate        DateTime      @db.Date
  issueDate      DateTime      @db.Date
  paidAt         DateTime?
  reference      String?
  ocrNumber      String?
  notes          String?

  // Synligt fel vid misslyckat e-postutskick (PDF-/mejl-jobbet). Sätts av
  // processInvoiceSendJob vid fel och nollställs vid lyckat utskick — samma
  // mönster som RentNotice.sendError. Statusen förblir DRAFT (utskicket skedde
  // aldrig); det här fältet + ett SEND_FAILED-event gör felet synligt i UI så
  // att hyresvärden kan skicka om. InvoiceStatus är en finansiell statusmaskin
  // (DRAFT→SENT→PAID …) utan FAILED — därför ett separat fält, inte en status.
  sendError      String?

  // Tracking-token för e-postspårning (pixel + PDF-länk)
  // Genereras vid skapande, används aldrig om – en faktura, ett token.
  trackingToken String @unique @default(uuid())

  // Påminnelse- och inkassoflöde
  remindersPaused      Boolean   @default(false)
  remindersPausedAt    DateTime?
  remindersPausedReason String?
  sentToCollectionAt   DateTime?
  collectionExportKey  String? // R2-nyckel till senaste inkassounderlag

  // Bokföringslagen (1999:1078): räkenskapsinformation måste bevaras 7 år.
  // Restrict hindrar att en org med fakturor raderas och förstör underlaget.
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  tenant           Tenant?            @relation(fields: [tenantId], references: [id])
  customer         Customer?          @relation(fields: [customerId], references: [id])
  lease            Lease?             @relation(fields: [leaseId], references: [id])
  lines            InvoiceLine[]
  events           InvoiceEvent[]
  bankTransactions BankTransaction[]
  deposit          Deposit?
  paymentReminders PaymentReminder[]
  consumptionCharges ConsumptionCharge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([trackingToken])
  @@index([ocrNumber])
}

// ─── Invoice Event Log ────────────────────────────────────────────────────────
// Immutabel append-only tabell. Inga UPDATE, inga DELETE (utom via Cascade).
// Svensk bokföringslag kräver 7 års retention – soft-delete vid org-borttagning.

model InvoiceEvent {
  id        String           @id @default(uuid())
  invoiceId String
  type      InvoiceEventType

  // Aktör – vem/vad som utlöste händelsen
  actorType  EventActorType
  actorId    String? // userId eller null för system/webhook
  actorLabel String? // Denormaliserat: "Anna Svensson" / "System" / "Postmark"

  // Händelsespecifik data – flexibel JSON per händelsetyp
  // t.ex. { email, provider, messageId } för e-postleverans
  // t.ex. { amount, paymentMethod, reference } för betalning
  // t.ex. { previousStatus, newStatus } för statusövergång
  payload Json @default("{}")

  // E-postspårnings-metadata
  ipAddress String?
  userAgent String?

  // Immutabilitetsgaranti: ingen updatedAt
  createdAt DateTime @default(now())

  // Bokföringslagen (1999:1078): InvoiceEvent är en append-only verifikationslogg.
  // Restrict hindrar att fakturans revisionsspår raderas vid borttagning.
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  // Komposit-index för tidslinjequery (en faktura, sorterat på tid)
  @@index([invoiceId, createdAt])
  // Index för filtrering per händelsetyp
  @@index([invoiceId, type])
  // Index för global aktivitetsfeed
  @@index([createdAt])
}

model InvoiceLine {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(10, 4)
  unitPrice   Decimal @db.Decimal(10, 2)
  vatRate     Int
  total       Decimal @db.Decimal(10, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// Idempotency-spärr för påminnelseflödet. UNIQUE (invoiceId, type) garanterar
// att samma typ av påminnelse aldrig skickas två gånger för en faktura, även
// vid cron-restart eller race conditions.
model PaymentReminder {
  id             String              @id @default(uuid())
  invoiceId      String
  type           PaymentReminderType
  sentAt         DateTime            @default(now())
  feeAmount      Decimal             @default(0) @db.Decimal(10, 2)
  emailMessageId String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, type])
  @@index([invoiceId])
  @@index([sentAt])
}

// ─── Accounting ───────────────────────────────────────────────────────────────

model Account {
  id             String      @id @default(uuid())
  organizationId String
  number         Int
  name           String
  type           AccountType
  parentId       String?
  isActive       Boolean     @default(true)

  // Bokföringslagen (1999:1078): kontoplanen är räkenskapsinformation, bevaras 7 år.
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  parent       Account?           @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[]          @relation("AccountHierarchy")
  journalLines JournalEntryLine[]

  @@unique([organizationId, number])
  @@index([organizationId])
}

model JournalEntry {
  id             String             @id @default(uuid())
  organizationId String
  date           DateTime           @db.Date
  description    String
  reference      String?
  source         JournalEntrySource @default(MANUAL)
  sourceId       String?
  // Nullable för automatiska poster (t.ex. auto-match från bank-import) där
  // ingen användare är inloggad. Manuella poster har alltid en createdBy.
  createdById    String?

  // ── Verifikationsnummer (BFL 5 kap 6 §) ───────────────────────────────────
  // Varje verifikation ska ha ett verifikationsnummer i en obruten nummerföljd
  // per serie och räkenskapsår. fiscalYear = det räkenskapsår posten hör till
  // (härlett ur date + Organization.fiscalYearStartMonth). series = "A"
  // (automatverifikat, SIE4-konvention). verNumber = löpnummer 1..N inom
  // (organizationId, series, fiscalYear), tilldelat atomiskt via
  // JournalEntrySequence inuti samma transaktion som posten skapas — en
  // rollback bränner därför aldrig ett nummer (gap-free).
  fiscalYear     Int
  series         String             @default("A")
  verNumber      Int

  // Bokföringslagen (1999:1078): journalposter är räkenskapsinformation, bevaras 7 år.
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdBy    User?              @relation(fields: [createdById], references: [id])
  lines        JournalEntryLine[]

  createdAt DateTime @default(now())

  // Obruten, unik nummerserie per (org, serie, räkenskapsår).
  @@unique([organizationId, series, fiscalYear, verNumber])
  // Idempotensspärr på DB-nivå: en affärshändelse (source+sourceId) får bara
  // bokföras en gång. Postgres behandlar NULL som distinkt, så manuella poster
  // (sourceId = null) berörs inte — endast automatiska poster med sourceId.
  @@unique([organizationId, source, sourceId])
  @@index([organizationId])
  @@index([date])
  @@index([organizationId, fiscalYear])
}

model JournalEntryLine {
  id             String   @id @default(uuid())
  journalEntryId String
  accountId      String
  debit          Decimal? @db.Decimal(10, 2)
  credit         Decimal? @db.Decimal(10, 2)
  description    String?

  // Restrict (ej Cascade): konteringsrader är räkenskapsinformation (BFL 1 kap
  // 2 § p.9, 5 kap 6 §) och får inte raderas. Append-only — rättelse sker via
  // motverifikat, aldrig radering. Systemet raderar aldrig verifikationer.
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

// Stänger en bokföringsperiod (månad+år) — efter close_period kan inga nya
// verifikat skapas med datum inom perioden. Append-only: en stängd period
// kan inte återöppnas via API (skulle kräva manuell DB-åtgärd).
model ClosedAccountingPeriod {
  id             String   @id @default(uuid())
  organizationId String
  month          Int
  year           Int
  closedAt       DateTime @default(now())
  closedById     String?
  summary        Json?

  // Bokföringslagen (1999:1078): stängda perioder är räkenskapsinformation, bevaras 7 år.
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  closedBy     User?        @relation(fields: [closedById], references: [id])

  @@unique([organizationId, year, month])
  @@index([organizationId])
}

// ─── Bank Reconciliation (Bankavstämning) ─────────────────────────────────────

model BankTransaction {
  id             String                @id @default(uuid())
  organizationId String
  date           DateTime
  description    String
  amount         Decimal               @db.Decimal(12, 2)
  balance        Decimal?              @db.Decimal(12, 2)
  reference      String?
  rawOcr         String?
  status         BankTransactionStatus @default(UNMATCHED)
  // PSD2 P1 — källidentitet & dedup. Bägge NULLABLE: befintliga fil-rader (och
  // all filimport) saknar externalId → oförändrade. `externalId` = bankens/
  // aggregatorns transaktions-id, unikt per org (API-vs-API-idempotens via
  // @@unique + create-och-fånga-P2002). `dedupKey` = deterministisk cross-source-
  // nyckel (Stockholm-dag + belopp + OCR) som fil OCH API stämplar likadant, så en
  // betalning som ingestas via BÅDA källorna vid migrationsöverlapp fångas som
  // dubblett istället för att dubbel-allokeras (#162-klassen). Rör EJ matchning.
  externalId     String?
  dedupKey       String?
  // Match-länkar — XOR. En transaktion kan matchas mot antingen en
  // kommersiell faktura (Invoice) eller en hyresavi (RentNotice), aldrig
  // båda. CHECK-constraint i migration garanterar invarianten på DB-nivå
  // så vi inte kan hamna i ett inkonsekvent state om en bug skriver båda.
  invoiceId            String?
  // Bankavstämnings-härdning PR 1 — @unique LYFT. Dubbel-allokeringsskyddet flyttas
  // till RentNoticePayment.bankTransactionId @unique (en bank-transaktion får
  // allokeras till exakt EN avi). matchedRentNoticeId blir en härledd spegel av
  // "vilken avi denna transaktion betalade" och kan på sikt delas av flera
  // transaktioner mot samma avi (delbetalning) — därför inte längre unik. Den
  // gamla race-garantin (en avi → en transaktion) bärs redan av den status-guardade
  // updateMany:en i applyMatchToRentNotice (claim.count), så ingen skyddslucka
  // uppstår. Index behålls för relation/uppslag.
  matchedRentNoticeId  String?
  matchedAt            DateTime?
  matchedBy            String?
  createdAt            DateTime              @default(now())

  // Bokföringslagen (1999:1078): banktransaktioner är räkenskapsinformation, bevaras 7 år.
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  invoice           Invoice?     @relation(fields: [invoiceId], references: [id])
  matchedRentNotice RentNotice?  @relation(fields: [matchedRentNoticeId], references: [id])
  // Härledd betalningsallokering (PR 1). Optional 1:1 — bankTransactionId @unique
  // på RentNoticePayment-sidan ger en allokering per transaktion.
  rentNoticePayment RentNoticePayment?

  @@unique([organizationId, externalId])
  @@index([organizationId])
  @@index([status])
  @@index([invoiceId])
  @@index([matchedRentNoticeId])
  @@index([organizationId, dedupKey])
}

// ─── Bank Statement Import (AI-tolkat kontoutdrag i PDF) ──────────────────────
// Sparas som DRAFT (PARSED) direkt efter AI-tolkning så användaren kan granska
// och redigera innan vi commitar BankTransaction-rader. När användaren bekräftar
// går vi via reconciliation.service.matchTransaction() — samma FIFO + dubbel-
// match-skydd som CSV/BgMax-flödena (Fix 6).

model BankStatementImport {
  id              String                     @id @default(uuid())
  organizationId  String
  fileName        String
  fileType        String // 'pdf' idag; reserverat för framtida 'csv','xlsx','bgmax'
  fileSize        Int
  status          BankStatementImportStatus  @default(PARSING)
  // uploadedBy / confirmedBy lagras som plain user-IDs (mirrors BankTransaction.matchedBy)
  uploadedById    String?
  uploadedAt      DateTime                   @default(now())

  // AI-extraherade metadata
  bank            String? // 'Swedbank' | 'SEB' | 'Nordea' | 'Handelsbanken' | 'Annan'
  accountNumber   String?
  periodStart     DateTime? @db.Date
  periodEnd       DateTime? @db.Date
  // BFL 5 kap 11 § (behandlingshistorik) + 7 kap 2 § (räkenskapsinformation, 7 år).
  // AI:ns RÅTOLKNING — sätts EN gång när status blir PARSED, ändras ALDRIG.
  // Gör att en granskare i efterhand kan se exakt vad Claude returnerade kontra
  // vad operatören ändrade (diff mot confirmedData). Endast PDF/AI-flödet behöver
  // detta: AI-tolkning är icke-deterministisk (modellberoende), så råtolkningen
  // måste bevaras separat. CSV/BgMax är deterministisk maskinparsning där
  // källfilen ensam utgör tillräcklig behandlingshistorik.
  originalParsedData Json?
  // Sparas som JSON: { transactions: [{ date, description, ocr, amount, isIncoming }, ...] }
  // Granskat/redigerat preview-tillstånd som UI:t läser under PARSED-fasen.
  parsedData      Json?
  // Den lista som FAKTISKT commitades till BankTransaction-rader — sätts EN gång
  // när status blir CONFIRMED, ändras ALDRIG. Räkenskapsinformation (BFL 1 kap 2 § 9c).
  confirmedData   Json?
  transactionCount Int                       @default(0)

  // Audit
  errorMessage    String?
  confirmedAt     DateTime?
  confirmedById   String?
  // Snapshot av matchningsresultatet vid bekräftelse
  matchedCount    Int?
  unmatchedCount  Int?

  // Bokföringslagen (1999:1078): underlag för räkenskapsinformation, bevaras 7 år.
  // Restrict matchar BankTransaction-mönstret — vi får inte tappa underlaget.
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

enum BankStatementImportStatus {
  PARSING   // Skickad till AI, väntar (transient — sync-flödet hoppar normalt över denna)
  PARSED    // AI gav giltig JSON, väntar på användarens granskning
  CONFIRMED // Användaren har bekräftat — BankTransaction-rader skapade
  FAILED    // Tolkning misslyckades (AI-fel / ogiltig JSON)
  CANCELLED // Användaren avbröt granskningen
}

// ── PSD2 P2: bankkoppling (samtycke + sync). ALLT inert bakom PSD2_ENABLED. ──────

enum BankConsentStatus {
  ACTIVE  // Giltigt samtycke — sync tillåten
  EXPIRED // SCA-omcertifiering krävs (~90 dagar)
  REVOKED // Återkallat (av användaren eller banken)
  ERROR   // Providern rapporterade fel — sync pausad
}

// Ett PSD2-samtycke per bankkoppling. access/refresh-tokens är app-layer-
// krypterade (AES-256-GCM) och lämnar ALDRIG backend (aldrig frontend/logg/AI).
// `organizationId` är sanningskällan för sync-scoping — härleds ALDRIG ur
// aggregatorns råsvar. onDelete: Restrict speglar BankTransaction (räkenskaps-
// underlag / spårbarhet får inte tappas).
model BankConsent {
  id              String            @id @default(uuid())
  organizationId  String
  provider        String            // 'STUB' | 'MOCK' | skarp adapter (P3)
  consentId       String            // aggregatorns samtyckes-id
  status          BankConsentStatus @default(ACTIVE)
  accessTokenEnc  String            // AES-256-GCM (base64 iv+tag+ct)
  refreshTokenEnc String?           // AES-256-GCM
  scope           String?
  expiresAt       DateTime?
  revokedAt       DateTime?
  lastSyncedAt    DateTime?
  syncCursor      String?           // inkrementell fetch (since) per konto/consent
  createdByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, provider, consentId])
  @@index([organizationId])
  @@index([status])
}

// Efemär CSRF-bindning för consent-redirecten (PSD2 SCA). `state` är en
// engångs-token; callbacken validerar den single-use och hämtar organizationId
// HÄRIFRÅN (server-lagrat), aldrig ur callback-queryn. Ingen org-relation —
// kortlivad och rensas efter förbrukning/utgång.
model Psd2ConsentState {
  id                String    @id @default(uuid())
  state             String    @unique
  organizationId    String
  provider          String
  initiatedByUserId String?
  consumedAt        DateTime? // single-use: sätts atomiskt vid callback
  expiresAt         DateTime
  createdAt         DateTime  @default(now())

  @@index([organizationId])
  @@index([expiresAt])
}

// ─── Batch-kontraktsskanning (PR1: datamodell + skanningskö + batch-tak) ──────
// En operatör laddar upp N kontrakts-PDF:er → varje rad skannas asynkront av
// den HÄRDADE ContractScannerService (#79) via Bull-kön. Speglar bankens
// draft/confirm-mönster (BankStatementImport): originalScanData är AI:ns
// oföränderliga råtolkning, reviewedData är den redigerbara kopian.
//
// PR1 STANNAR vid skanning: ingen rad matchas mot en Unit (PR2) och ingen
// commit-väg finns (PR3) — det går alltså inte att skapa ett avtal härifrån.
model ContractImportBatch {
  id             String                    @id @default(uuid())
  organizationId String
  status         ContractImportBatchStatus @default(PENDING)
  // Plain user-ID (mirrors BankStatementImport.uploadedById).
  uploadedById   String?
  uploadedAt     DateTime                  @default(now())

  totalRows   Int @default(0)
  scannedRows Int @default(0)
  failedRows  Int @default(0)

  // Kostnadstak (PR1). estimatedCostSek beräknas heuristiskt INNAN skanningen
  // enqueueas; fileCapApplied/costCapApplied snapshotar de gränser som gällde
  // (per-org eller default) så ett historiskt batch-beslut kan rekonstrueras.
  estimatedCostSek Decimal @default(0) @db.Decimal(10, 2)
  fileCapApplied   Int
  costCapApplied   Decimal @db.Decimal(10, 2)

  errorMessage String?

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rows         ContractImportRow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

model ContractImportRow {
  id             String  @id @default(uuid())
  batchId        String
  // Denormaliserat så workern kan org-scopa skanningen utan att joina batchen.
  organizationId String

  fileName String
  fileSize Int
  // Rå PDF-bytes lagras TRANSIENT i DB och purgeas (sätts till null) så snart
  // den inte längre behövs: vid lyckad skanning (originalScanData är då sparat)
  // och vid avbruten batch. Råa PDF:er finns därmed bara på PENDING/SCANNING-
  // rader — en SCANNAD rad bär aldrig kvar ett kontrakt med personnummer.
  // Batch-taket + 10 MB-gränsen per fil (MAX_CONTRACT_BYTES) begränsar
  // svällrisken; R2-objektlagring kan ersätta detta i v2 om DB sväller.
  fileData Bytes?

  rowStatus ContractImportRowStatus @default(PENDING)

  // Speglar bankens tre-lagers-mönster. originalScanData sätts EN gång när
  // skanningen lyckas (ContractScannerService:s oföränderliga råtolkning);
  // reviewedData är en redigerbar kopia (identisk vid SCANNED). confirmedData/
  // createdLeaseId (PR3) tillkommer i senare snitt.
  originalScanData Json?
  reviewedData     Json?
  confidence       Float?

  // Deterministisk enhetsmatchning (PR2). matchStatus är null tills raden
  // skannats; därefter ett FÖRSLAG på vilken Unit kontraktet gäller. matchedUnit
  // sätts endast vid AUTO_MATCHED (exakt EN kandidat). Detta är ENBART ett
  // förslag — inget avtal skapas (det kräver mänskligt godkännande i PR3).
  // FK med SetNull: tas den föreslagna enheten bort försvinner förslaget.
  matchStatus   ContractRowMatchStatus?
  matchedUnitId String?
  matchedUnit   Unit?                   @relation(fields: [matchedUnitId], references: [id], onDelete: SetNull)

  // Commit (PR3). confirmedData fryses EN gång när operatören godkänner raden
  // (de exakta avtalsfält som skickades till /leases/with-tenant — audit).
  // createdLeaseId är en idempotensnyckel: är den satt har raden redan skapat
  // ett avtal och committas ALDRIG igen. Plain ID (ingen FK), speglar
  // BankStatementImport.confirmedById — en audit-pekare, inte en hård relation.
  confirmedData  Json?
  createdLeaseId String?

  errorMessage String?

  batch ContractImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([organizationId])
  @@index([rowStatus])
  @@index([matchedUnitId])
}

enum ContractRowMatchStatus {
  AUTO_MATCHED // Exakt EN kandidat-Unit matchade (adress + lägenhetsnummer)
  AMBIGUOUS    // Flera kandidater matchade — lämnas orörd (ingen gissning)
  NO_MATCH     // Noll kandidater matchade
  NEEDS_REVIEW // Saknat adress-/lägenhetsfält eller låg skanningskonfidens
}

enum ContractImportBatchStatus {
  PENDING   // Skapad, rader köade men ännu inte klara
  SCANNING  // Minst en rad skannas
  SCANNED   // Alla rader klara (lyckade eller failade) — väntar på granskning
  COMPLETED // Alla rader committade/hoppade/failade — granskningen avslutad (PR3)
  FAILED    // Batch-nivå-fel (t.ex. kostnadsbroms slog till under körning)
  CANCELLED // Operatören avbröt
}

enum ContractImportRowStatus {
  PENDING    // Köad, ännu inte skannad
  SCANNING   // Hämtad av workern
  SCANNED    // ScannedContract lagrad i originalScanData/reviewedData
  COMMITTING // Transient lås under commit — hindrar dubbel-create vid samtidiga godkännanden (PR3)
  COMMITTED  // Operatören godkände → avtal skapat via /leases/with-tenant (PR3)
  SKIPPED    // Operatören valde att inte skapa avtal för raden (PR3)
  FAILED     // Skanning misslyckades (alla retries slut / ogiltig fil / kostnadsbroms)
}

// ─── Document (Dokumentarkiv) ─────────────────────────────────────────────────

model Document {
  id             String           @id @default(uuid())
  organizationId String
  name           String
  description    String?
  storageKey     String
  storageUrl     String
  fileSize       Int
  mimeType       String
  category       DocumentCategory @default(OTHER)
  propertyId     String?
  unitId         String?
  leaseId        String?
  tenantId       String?
  uploadedById   String?

  // ── Signering & versionskedja (används primärt för CONTRACT) ─────────────
  // contentHash är SHA-256 över PDF-bytena vid signeringstillfället. När
  // locked = true får storageKey/storageUrl ej ändras — ny version skapas
  // istället och refereras via previousVersionId.
  contentHash       String?
  signedAt          DateTime?
  signedByTenantId  String?
  signedFromIp      String?
  signedUserAgent   String?
  // Hyresgästens skrivna namnunderskrift vid signering. Lagras separat
  // från signedByTenant så att vi har två oberoende identitetsspår: vem
  // som autentiserade (FK) och vad de själva skrev (fritext).
  signatureName     String?
  locked            Boolean   @default(false)
  previousVersionId String?

  // SHA-256-fingerprint av template-INPUT (lease/tenant/unit/property/org-snapshot)
  // som PDF:en byggdes från. Används för att dedupa kontrakts-PDF:er när admin
  // klickar "Generera" upprepade gånger utan att något har ändrats — då
  // återanvänder vi den befintliga raden istället för att skapa nya versioner.
  // Skiljer sig från contentHash som hashar PDF-bytena (dessa varierar p.g.a.
  // Puppeteer-timestamps även för identisk input).
  templateInputHash String?

  // ── Kontraktsbilaga (Kontraktsmall 2.0) ────────────────────────────────
  // När true bifogas dokumentet i hyreskontraktets bilageförteckning
  // (sista sidan av PDF:en). appendixOrder styr sorteringen — låga tal
  // först. Bara meningsfullt när leaseId är satt.
  attachedToLeaseAsAppendix Boolean @default(false)
  appendixOrder             Int?

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property         Property?    @relation(fields: [propertyId], references: [id])
  unit             Unit?        @relation(fields: [unitId], references: [id])
  lease            Lease?       @relation(fields: [leaseId], references: [id])
  tenant           Tenant?      @relation(fields: [tenantId], references: [id])
  uploadedBy       User?        @relation(fields: [uploadedById], references: [id])
  signedByTenant   Tenant?      @relation("DocumentSignedByTenant", fields: [signedByTenantId], references: [id])
  previousVersion  Document?    @relation("DocumentVersionChain", fields: [previousVersionId], references: [id])
  newerVersions    Document[]   @relation("DocumentVersionChain")
  signingRequests  SigningRequest[] @relation("DocumentSigningRequests")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([propertyId])
  @@index([unitId])
  @@index([leaseId])
  @@index([tenantId])
  @@index([previousVersionId])
  @@index([leaseId, attachedToLeaseAsAppendix])
  // Snabb lookup för dedup-fönstret i ContractTemplateService — vi söker
  // (leaseId, category=CONTRACT, templateInputHash=X) för att hitta
  // återanvändbar PDF utan att scanna alla dokument på leasen.
  @@index([leaseId, category, templateInputHash])
}

// ─── Signering (Item 4, S-serien) ─────────────────────────────────────────────
// BankID-signering av kontrakt via en provider-agnostisk DocumentSigningProvider
// (dedikerad e-signering, Scrive/Assently — inert bakom SIGNING_ENABLED tills
// avtal/nycklar finns i S3). SigningRequest = envelope-aggregatet (EXPLICIT status,
// aldrig härledd). SignatureEvidence = append-only bevis per part.

enum SigningRequestStatus {
  PENDING // skapad, contentHash fryst, väntar på att skickas till provider
  SIGNING_IN_PROGRESS // skickad till provider / minst en part påbörjat → blockerar PDF-regenerering
  PARTIALLY_SIGNED // minst en men inte alla obligatoriska parter klara
  FULLY_SIGNED // alla obligatoriska parter signerat
  DECLINED // en part avvisade
  EXPIRED
  CANCELLED
  ERROR
}

enum SignerRole {
  LANDLORD
  TENANT
}

model SigningRequest {
  id                String               @id @default(uuid())
  organizationId    String
  documentId        String
  leaseId           String?
  // FRYST vid createRequest — WYSIWYS-ankaret. Regenerering av kontraktet
  // blockeras medan status är SIGNING_IN_PROGRESS (se ContractTemplateService).
  contentHash       String
  provider          String // 'MOCK' | 'STUB' | 'SCRIVE' | 'ASSENTLY'
  providerRequestId String? // leverantörens envelope-id (sätts när skickat)
  // = sha256(documentId + contentHash) — samma dokument+version → samma request
  // (idempotent "skicka igen").
  idempotencyKey    String
  status            SigningRequestStatus @default(PENDING)
  // Explicit lista över förväntade signerare (t.ex. ["TENANT"]) — "alla klara?"
  // räknas mot DENNA, aldrig härlett från antal evidence-rader.
  requiredRoles     Json
  expiresAt         DateTime?
  sealedDocumentId  String? // förseglad PDF (ny låst Document-version), sätts när klar
  createdByUserId   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt // OK på envelope-aggregatet (ej på beviset)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  document     Document            @relation("DocumentSigningRequests", fields: [documentId], references: [id], onDelete: Restrict)
  evidence     SignatureEvidence[]

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId])
  @@index([documentId])
  @@index([status])
}

// APPEND-ONLY juridiskt signeringsbevis per part. INGEN updatedAt (som InvoiceEvent).
// onDelete: Restrict på ALLA relationer — en org-/request-radering får ALDRIG tyst
// ta bort beviset (BFL/bevis-anda). Känsliga fält (personalNumberEnc/Hash,
// signaturePayload, certificate, orderRef) når ALDRIG portal/AI (allow-list-select).
model SignatureEvidence {
  id                 String     @id @default(uuid())
  organizationId     String
  signingRequestId   String
  documentId         String // denormaliserat för snabb lookup (integritet via signingRequest)
  signerRole         SignerRole
  signerName         String
  personalNumberEnc  String // AES-256-GCM envelope-krypterat
  personalNumberHash String // HMAC-blind-index (matchning/uppslag utan att exponera personnr)
  provider           String
  orderRef           String // leverantörens transaktions-/orderRef
  signedContentHash  String // hashen som FAKTISKT signerades (== SigningRequest.contentHash)
  signaturePayload   String? // rå signatur, krypterad — KRITISK, aldrig till portal/AI
  certificate        String? // krypterad
  signedAt           DateTime
  ip                 String?
  userAgent          String?
  createdAt          DateTime   @default(now())

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  signingRequest SigningRequest @relation(fields: [signingRequestId], references: [id], onDelete: Restrict)

  // Idempotens: samma leverantörs-transaktion kan aldrig ge två bevisrader.
  @@unique([organizationId, provider, orderRef])
  @@index([organizationId])
  @@index([signingRequestId])
  @@index([documentId])
}

// ─── ContractNumberSequence (Kontraktsmall 2.0) ───────────────────────────────
// Per-organisation, per-år löpnummer för kontrakt. Vi kör en SELECT FOR UPDATE
// inom transaktion + UPSERT — Postgres kan därför aldrig dela ut samma nummer
// två gånger även vid samtidiga DRAFT→ACTIVE-aktiveringar. Liknar fakturornas
// nummersystem men en separat tabell så vi kan ha andra format/regler om de
// divergerar i framtiden.
model ContractNumberSequence {
  organizationId String
  year           Int
  lastNumber     Int      @default(0)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([organizationId, year])
}

// Per-organisation löpnummer för felanmälningsärenden (UND-{nnnnn}). En rad
// per organisation. UPSERT med atomär increment ger Postgres row-lock så
// att samtidiga ärendeskapande inte kan dela ut samma nummer två gånger.
model MaintenanceTicketSequence {
  organizationId String   @id
  lastNumber     Int      @default(0)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// Verifikationsnummerserie per organisation, räkenskapsår och serie (BFL 5 kap
// 6 §). En rad per (org, fiscalYear, series). UPSERT med atomär increment ger
// Postgres row-lock så att samtidiga verifikationer aldrig delar ut samma
// nummer (race-säkert), och eftersom allokeringen sker inuti samma transaktion
// som JournalEntry skapas blir serien obruten (gap-free) — en rollback
// återställer även increment:en. onDelete Restrict: sekvensen är en del av
// bokföringsintegriteten.
model JournalEntrySequence {
  organizationId String
  fiscalYear     Int
  series         String   @default("A")
  lastNumber     Int      @default(0)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@id([organizationId, fiscalYear, series])
}

// Plattformsglobal löpnummerserie för organisationernas kundnummer
// (K-100001, K-100002 …). Till skillnad från de övriga sekvenserna ovan är
// denna INTE scopad per organisation — kundnumret är unikt över hela
// plattformen. Därför en enda rad, vaktad av ett konstant id ("GLOBAL"):
// allokeringen sker via en UPSERT med atomär increment som tar Postgres
// row-lock på just den raden, så två samtidiga org-skapanden aldrig delar ut
// samma nummer. Ett hål i serien är ofarligt (kundnumret är ingen BFL-reglerad
// verifikations-/fakturaserie), så allokeringen kräver ingen omslutande
// transaktion — till skillnad från InvoiceNumberSequence nedan.
model CustomerNumberSequence {
  id         String   @id @default("GLOBAL")
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt
}

// Global löpnummerserie för fakturanummer per organisation (ML 11 kap 8 §:
// fortlöpande serie som entydigt identifierar fakturan). En rad per org;
// numret nollställs INTE per år (året i F-{år}-{nr} är kosmetiskt, numret är
// global obruten sekvens — bevarar OCR-unikhet som härleds ur sekvensen).
// Atomär increment via UPSERT inuti faktura-transaktionen → race-säkert och
// gap-free. onDelete Restrict: del av bokföringsintegriteten.
model InvoiceNumberSequence {
  organizationId String   @id
  lastNumber     Int      @default(0)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
}

// Riksbankens referensränta (räntelagen 1975:635 9 §), fastställd HALVÅRSVIS
// (gäller 1 jan / 1 jul). Dröjsmålsräntan på obetald hyra är referensränta +
// 8 procentenheter (räntelagen 6 §). Referensräntan får ALDRIG hårdkodas i
// beräkningslogiken — den lever som data här och läses utifrån vilket datum
// dröjsmålet avser (PR 3). Plattformsglobal (nationell ränta, INTE org-scopad,
// ingen organizationId-kolumn, ingen tenant-data). En rad per halvår; PR 1
// seedar gällande värde men INGEN kod läser tabellen än. Append-historik:
// gamla rader raderas aldrig — historiska dröjsmål ska kunna räknas om mot den
// ränta som gällde då. ratePercent kan vara negativ (referensräntan har
// historiskt varit < 0).
model ReferenceInterestRate {
  id            String   @id @default(uuid())
  // Gäller fr.o.m. detta datum t.o.m. nästa rads effectiveFrom (halvårsskifte).
  effectiveFrom DateTime @db.Date
  ratePercent   Decimal  @db.Decimal(5, 2)
  // Revisorsspår: var värdet kommer ifrån, t.ex. "Riksbanken, beslut 2025-12".
  source        String?
  createdAt     DateTime @default(now())

  @@unique([effectiveFrom])
  @@index([effectiveFrom])
}

// ─── AI Assistant ─────────────────────────────────────────────────────────────

model AiConversation {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  title          String   @default("Ny konversation")
  // Sliding-window-cache för långa konversationer (>30 meddelanden).
  // `summary` är en Haiku-genererad svensk sammanfattning av meddelandena
  // FÖRE de senaste 20. `summarizedUpToMessageId` pekar på det sista
  // meddelandet som ingick i cachen — när ≥10 nya meddelanden hamnat i
  // "old"-tiern regenereras summary. Är NULL för korta konversationer
  // och alla konversationer som existerade innan kolumnerna lades till.
  summary                 String?  @db.Text
  summarizedUpToMessageId String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     AiMessage[]
  pendingActions AiPendingAction[]

  @@index([organizationId])
  @@index([userId])
}

// SECURITY (AI-architect RISK 1): server-lagrad pending action. När AI:n
// föreslår en action-tool persisteras den här (hash av toolName+toolInput).
// confirm-endpointen MÅSTE matcha mot en icke-konsumerad, ej utgången rad —
// annars kan en klient bekräfta en godtycklig åtgärd (t.ex. create_journal_entry
// med egna belopp) som AI:n aldrig föreslog och kringgå human-in-the-loop.
// Engångsbruk (consumedAt) + 5 min TTL + scope på (org, user, conversation).
model AiPendingAction {
  id             String    @id @default(uuid())
  conversationId String
  organizationId String
  userId         String
  toolName       String
  // SHA-256 av kanonisk JSON av { toolName, toolInput }. Vi lagrar bara hashen
  // — den faktiska inputen finns i AI-meddelandet och skickas av klienten.
  toolInputHash  String
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime  @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([organizationId, userId])
  @@index([expiresAt])
}

model AiMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String // "user" | "assistant"
  content        String
  // Anthropic ContentBlock[] från final-turn (text + ev. tool_use).
  // Sparas av assistant-rader så att AI:n vid återupptaget samtal får
  // typade block tillbaka istället för bara extraherad text. Är NULL
  // för (a) user-meddelanden, (b) action-tool confirmation-svar, och
  // (c) alla rader som skapades innan denna kolumn lades till.
  // Loading-koden faller tillbaka till `content` om `blocks` saknas
  // — backwards-compatible.
  blocks         Json?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum AiMemoryType {
  preference
  fact
  relationship
  convention
}

model AiMemory {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  key            String
  value          String       @db.Text
  type           AiMemoryType @default(fact)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, key])
  @@index([organizationId, userId])
}

// Spårar varje Anthropic-anrop med token-användning och uppskattad kostnad.
// Används av AiQuotaService för att stoppa orgs som överskrider månads-budget,
// samt för rapporter över AI-användning.
//
// Endera userId (fastighetsägar-AI) eller tenantId (hyresgäst-AI) är satt.
model AiUsageLog {
  id               String   @id @default(uuid())
  organizationId   String
  userId           String?
  tenantId         String?
  // 'chat' | 'stream' | 'analysis' | 'memory' | 'contract-scan' | 'inspection-analyze' | 'daily-insights' | 'tenant-chat'
  endpoint         String
  model            String
  inputTokens      Int      @default(0)
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  outputTokens     Int      @default(0)
  costUsd          Decimal  @db.Decimal(10, 6)
  costSek          Decimal  @db.Decimal(10, 4)
  // isAutomated=true: anropet utlöstes av schemalagd automation (morning
  // insights, OCR, kontraktsskanning, tenant-AI, bankavstämning). Räknas
  // EJ mot månadens manuella anropstak — kostnaden ingår i baspriset.
  // isAutomated=false: anropet kommer från admin via AiPage / chat.
  isAutomated      Boolean  @default(false)
  // Subtyp för observabilitet: 'manual_chat', 'morning_insights',
  // 'ocr_invoice', 'contract_scan', 'tenant_chat', 'bank_match'…
  source           String?
  createdAt        DateTime @default(now())

  // Revisionsspår: AI-användningsloggen måste bevaras vid org-borttagning (Restrict).
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenant       Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, isAutomated, createdAt])
  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
}

// Audit-logg för varje AI-tool-exekvering. Krävs för GDPR och för att kunna
// utreda vad AI:n faktiskt gjorde i en organisations data.
//
// toolInput och toolResult lagras som JSON, men personnummer och
// organisationsnummer maskeras innan persistens (se ai-audit.service.ts).
//
// Endera userId (fastighetsägare) eller tenantId (hyresgäst) är satt.
model AiToolExecution {
  id                   String   @id @default(uuid())
  organizationId       String
  userId               String?
  tenantId             String?
  conversationId       String?
  toolName             String
  toolInput            Json
  toolResult           Json?
  success              Boolean
  errorMessage         String?
  durationMs           Int
  requiredConfirmation Boolean  @default(false)
  confirmedAt          DateTime?
  createdAt            DateTime @default(now())

  // Revisionsspår: AI-verktygskörningar måste bevaras vid org-borttagning (Restrict).
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  // SetNull (matchar AiUsageLog): revisionsspåret bevaras även om användare/hyresgäst raderas.
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenant       Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([toolName])
}

// Hyresgäst-AI: separata tabeller från AiConversation/AiMessage för att hålla
// fastighetsägar- och hyresgäst-konversationer isolerade. Hyresgästen får
// ALDRIG se en konversation från en annan hyresgäst (cascade på Tenant.id
// säkerställer också att raderade hyresgäster städar sin chathistorik).
model AiTenantConversation {
  id        String   @id @default(uuid())
  tenantId  String
  title     String   @default("Ny konversation")
  // SECURITY (RISK 1, tenant): pending-action-bindning. Sätts när AI:n föreslår
  // en action-tool; confirm-endpointen kräver att hashen matchar och inte gått
  // ut (5 min). Annars kan en hyresgäst POST:a confirm med request_termination
  // utan att ha chattat. En aktiv pending action i taget per konversation.
  pendingActionHash      String?
  pendingActionExpiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages AiTenantMessage[]

  @@index([tenantId, updatedAt])
}

model AiTenantMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String // "user" | "assistant"
  content        String
  createdAt      DateTime @default(now())

  conversation AiTenantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ─── Termination Request (uppsägningsbegäran från hyresgäst) ─────────────────

enum TerminationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model TerminationRequest {
  id               String                   @id @default(uuid())
  organizationId   String
  tenantId         String
  leaseId          String
  requestedEndDate DateTime
  reason           String?
  status           TerminationRequestStatus @default(PENDING)
  reviewedAt       DateTime?
  reviewedById     String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease        Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([tenantId])
  @@index([leaseId])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id                 String           @id @default(uuid())
  organizationId     String
  userId             String
  type               NotificationType
  title              String
  message            String
  link               String?
  relatedEntityType  String?
  relatedEntityId    String?
  read               Boolean          @default(false)
  readAt             DateTime?
  createdAt          DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([read])
  @@index([createdAt])
}

// ─── Import Job ───────────────────────────────────────────────────────────────

model ImportJob {
  id             String          @id @default(uuid())
  organizationId String
  type           ImportJobType
  status         ImportJobStatus @default(PENDING)
  filename       String
  totalRows      Int             @default(0)
  processedRows  Int             @default(0)
  successRows    Int             @default(0)
  errorRows      Int             @default(0)
  errors         Json            @default("[]")
  createdById    String
  createdAt      DateTime        @default(now())
  completedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId])
}

// ─── Maintenance (Underhåll) ──────────────────────────────────────────────────

model MaintenanceTicket {
  id             String  @id @default(uuid())
  ticketNumber   String
  organizationId String
  propertyId     String
  unitId         String?
  tenantId       String?
  reportedById   String?
  assignedToId   String?

  title       String
  description String              @db.Text
  category    MaintenanceCategory @default(OTHER)
  priority    MaintenancePriority @default(NORMAL)
  status      MaintenanceStatus   @default(NEW)

  estimatedCost Decimal? @db.Decimal(10, 2)
  actualCost    Decimal? @db.Decimal(10, 2)

  scheduledDate DateTime?
  completedAt   DateTime?

  tenantToken    String? @unique
  tenantNotified Boolean @default(false)

  // Debiterbar post som genererats från ärendet (teknisk förvaltning, Spår A).
  // 1:1, FK på ticket-sidan med Restrict (en bokförd MiscCharge är bevis och får
  // inte försvinna under ärendet). Låter ärendet veta om det redan debiterats.
  //
  // AVSIKTLIG DUBBELLÄNK (ai-architect) — ta INTE bort som "duplicering": denna
  // hårda FK (chargeId) ger referensintegritet för den kända v1-källan
  // (MAINTENANCE_TICKET). MiscCharge.sourceType/sourceRefId är den GENERISKA
  // metadatan som framtida källor (INSPECTION_ITEM, KEY_LOSS) använder UTAN egen
  // FK uppåt. De pekar medvetet mot varandra för maintenance-fallet.
  chargeId String? @unique

  images   MaintenanceImage[]
  comments MaintenanceComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id])
  unit         Unit?        @relation(fields: [unitId], references: [id])
  tenant       Tenant?      @relation(fields: [tenantId], references: [id])
  charge       MiscCharge?  @relation(fields: [chargeId], references: [id], onDelete: Restrict)

  @@unique([organizationId, ticketNumber])
  @@index([organizationId])
  @@index([propertyId])
  @@index([status])
}

model MaintenanceImage {
  id         String   @id @default(uuid())
  ticketId   String
  filename   String
  storageKey String
  storageUrl String
  size       Int
  createdAt  DateTime @default(now())

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model MaintenanceComment {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String?
  content    String   @db.Text
  isInternal Boolean  @default(true)
  createdAt  DateTime @default(now())

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

// ─── Rent Notice (Hyresavi) ───────────────────────────────────────────────────

model RentNotice {
  id             String           @id @default(uuid())
  organizationId String
  tenantId       String
  leaseId        String
  noticeNumber   String
  ocrNumber      String
  month          Int
  year           Int
  amount         Decimal          @db.Decimal(10, 2)
  vatAmount      Decimal          @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal          @db.Decimal(10, 2)
  dueDate        DateTime
  paidAt         DateTime?
  paidAmount     Decimal?         @db.Decimal(10, 2)
  // Betalningssätt vid manuell betalningsregistrering (markAsPaid). Nullbar:
  // historiska/obetalda avier saknar värde, och bankavstämda betalningar
  // (reconciliation) sätter det inte. Styr debetkontot i betalningsverifikatet.
  paymentMethod  PaymentMethod?
  status         RentNoticeStatus @default(PENDING)
  sentAt         DateTime?
  sentTo         String?
  sendError      String?

  // ── Typ + proportionell hyra (delmånad) ─────────────────────────────────
  // type skiljer ren månadshyra från deposition. Periodfälten används av
  // PDF-mallen för att visa "9 maj – 31 maj (23/31 dagar)".
  type        RentNoticeType @default(RENT)
  periodStart DateTime?      @db.Date
  periodEnd   DateTime?      @db.Date
  daysCharged Int?
  totalDays   Int?
  isProrated  Boolean        @default(false)

  // ── Förbrukningsdebitering (IMD, rad-på-avi) ────────────────────────────
  // amount/vatAmount/totalAmount avser HYRAN (bokförs av hyresverifikatet,
  // oförändrat). consumptionAmount är summan av förbrukningsrader (brutto) och
  // ingår i den betalbara totalen/OCR — men bokförs via egna periodiserade
  // verifikat (PR 3), inte här. Default 0. Rader i RentNoticeLine (PR 4).
  consumptionAmount Decimal @default(0) @db.Decimal(10, 2)

  // Övriga debiterbara poster (MiscCharge, teknisk förvaltning Spår A) som rader
  // på avin — skada/nyckel m.m. SPEGLAR consumptionAmount: brutto, ingår i den
  // betalbara totalen/OCR/skuld men bokförs via eget verifikat (1510 D / 3990 K,
  // PR 2/3), inte här. ALDRIG hopslaget med consumptionAmount — IMD-attach skriver
  // över det fältet vid varje generering, och rapportering håller isär IMD från
  // skadedebitering. Default 0. Rader i RentNoticeLine.miscChargeId (PR 4b).
  miscChargeAmount Decimal @default(0) @db.Decimal(10, 2)

  // ── Kravtrappa (inkasso-serien) ─────────────────────────────────────────
  // Additiva fält — RentNotice bär redan stora delar av "inkasso-ready"-datan
  // (dueDate, sentAt/sentTo/sendError = leveransstatus, bankTransactions =
  // betalningshistorik, PDF-spår). Detta lägger till själva kravtrappan.
  // collectionStage default NONE → befintlig avi-generering påverkas inte.
  // Tidsstämplarna sätts av respektive PR (remindedAt PR 2, collectionReadyAt
  // PR 4, writtenOffAt PR 5). PR 1 skriver ingen av dem.
  collectionStage   RentCollectionStage @default(NONE)
  remindedAt        DateTime?
  collectionReadyAt DateTime?
  writtenOffAt      DateTime?
  // Inkasso PR 5 — befarad kundförlust. Sätts ATOMISKT med omklassningsverifikatet
  // (1515 D / 1510 K) när en inkasso-redo, MOMSFRI fordran klassas som osäker.
  // Markören driver kravtrappans terminalsteg: befarad (probableLossAt) → konstaterad
  // (writtenOffAt + stage WRITTEN_OFF, 6352 D / 1515 K). Ändrar INTE kravsteget i sig
  // (befarad är en balansräkningsomklassning, ingen ny kravstegsövergång).
  probableLossAt    DateTime?

  // Påminnelseavgift (inkasso PR 2). Default 0 → ingen påverkan på icke-påminda
  // avier. Sätts ATOMISKT med påminnelseavgiftens verifikat (1510 D / 3593 K) när
  // avin eskaleras till REMINDED. Hålls SKILD från totalAmount (hyran, som styr
  // hyresverifikatet) och consumptionAmount (IMD) — men ingår i den betalbara
  // totalen/OCR (rentNoticePayableTotal) så att fordran på 1510 och det avin
  // kräver in är konsistenta. Momsfri (avgiften är en påföljd, inte omsättning).
  reminderFeeAmount Decimal @default(0) @db.Decimal(10, 2)

  // Ackumulerad dröjsmålsränta (inkasso PR 3). Kumulativt bokfört räntebelopp
  // (1510 D / 8131 K, finansiell intäkt — INTE 3593) och datumet räntan är
  // beräknad t.o.m. Räntan kristalliseras vid bestämda punkter (påminnelse,
  // inkasso-ready) och bokförs inkrementellt (delta mot redan bokfört). Default 0.
  // Till SKILLNAD från reminderFeeAmount ingår räntan INTE i rentNoticePayableTotal:
  // dröjsmålsräntan löper kontinuerligt och är en separat fordran som regleras vid
  // slutuppgörelse (inkasso/betalning av hela kravet), inte ett fast OCR-belopp.
  // Exponeras på avin så den kan följa med i inkasso-exporten (PR 4).
  interestAccruedAmount  Decimal   @default(0) @db.Decimal(10, 2)
  interestAccruedThrough DateTime?

  // Inkasso PR 4b₀ — dokumentationsinfrastruktur som gör INV-B uppfyllbar i PR 4b
  // (inget av detta rör status, bokföring eller export — ren infrastruktur).
  //
  // reminderPdfStorageKey: R2-nyckeln till den FAKTISKT skickade påminnelse-PDF:en.
  // Tidigare renderades den i processReminderSendJob, mejlades och kastades; nu
  // laddas den upp org-scopat (reminders/{orgId}/…) så dokumentkopian kan följa med
  // i inkassoöverlämningen (PR 2-backlog, hyresjurist LOW).
  //
  // reminderMessageId: Resends message-id (email_id) för påminnelseutskicket —
  // webhookens ENDA korrelationsnyckel mot rätt avi, exakt som
  // Tenant.lastInviteMessageId för portalinbjudan. @unique gör korrelationen
  // entydig på DB-nivå: ett leverans-/bounce-event kan aldrig träffa mer än en avi
  // (ingen cross-tenant-skrivning). Sätts av PdfWorker EFTER lyckad Resend-send.
  // Leveransutfallet loggas append-only i RentNoticeEvent (EMAIL_DELIVERED/
  // EMAIL_BOUNCED), inte som muterbara kolumner här.
  reminderPdfStorageKey String?
  reminderMessageId     String? @unique

  // Bokföringslagen (1999:1078): hyresavier är räkenskapsinformation, bevaras 7 år.
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  lease            Lease             @relation(fields: [leaseId], references: [id])
  deposit          Deposit?
  bankTransactions BankTransaction[]
  lines            RentNoticeLine[]
  events           RentNoticeEvent[]
  // Bankavstämnings-härdning PR 1 — granulära betalningsallokeringar. Källa till
  // sanning för "hur mycket är betalt" (RentDebtService.outstanding läser dessa);
  // paidAmount/matchedRentNoticeId blir härledda speglar. En avi kan på sikt bära
  // flera allokeringar (delbetalning över flera bank-transaktioner). Cascade: en
  // allokering är härledd data, inte verifikat — själva verifikatet (JournalEntry)
  // är räkenskapsinformationen och rörs aldrig av den här tabellen.
  payments         RentNoticePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Idempotency på (lease, period, typ) — samma månad får INTE generera två
  // RENT-avier eller två DEPOSIT-avier. Det gamla unique på (org,tenant,month,
  // year) räcker inte när tenant har flera kontrakt eller när vi även lagrar
  // DEPOSIT i samma tabell.
  @@unique([leaseId, year, month, type])
  // H1: avinummer är unikt PER ORGANISATION, inte globalt. Det gamla globala
  // @unique på noticeNumber gjorde att två orgar inte kunde dela samma
  // AVI-2026-06-0001. Den composite unique:n indexerar även (organizationId,
  // noticeNumber) → nextNoticeNumber-prefixsökningen slipper full table scan.
  @@unique([organizationId, noticeNumber])
  @@index([organizationId])
  @@index([status])
  @@index([dueDate])
  @@index([leaseId])
  // Kravtrappa-jobben (PR 2–5) filtrerar avier per steg per org.
  @@index([organizationId, collectionStage])
}

// Radpost på en hyresavi. Idag bär RentNotice bara ett samlat amount; denna
// tabell gör det möjligt att visa "Hyra 7 000 / El 240 kr" på samma avi och ett
// OCR (leveranssätt RENT_NOTICE_LINE, PR 4). Speglar InvoiceLine. consumption-
// ChargeId kopplar raden till sin förbrukningspost (null för framtida manuella
// tilläggsrader). Cascade mot avin (som InvoiceLine mot Invoice); avin själv är
// Restrict-skyddad mot org → räkenskapsinformationen består.
model RentNoticeLine {
  id           String  @id @default(uuid())
  rentNoticeId String
  description  String
  quantity     Decimal @db.Decimal(10, 4)
  unitPrice    Decimal @db.Decimal(10, 2)
  vatRate      Int     @default(0)
  total        Decimal @db.Decimal(10, 2)

  consumptionChargeId String? @unique
  // Övrig debiterbar post (teknisk förvaltning) som rad på avin. Restrict: en
  // bokförd MiscCharge får inte försvinna under avi-raden (charges är bevis,
  // speglar consumption-charges Restrict-hållning). FK på line-sidan, 1:1.
  //
  // XOR-INVARIANT: exakt EN av consumptionChargeId / miscChargeId får vara satt
  // på en charge-rad (en rad är antingen en förbruknings- eller en övrig post,
  // aldrig båda). Detta tvingas i service-lagret (PR 3), inte i schemat —
  // Prisma kan inte uttrycka ett villkorligt XOR-constraint.
  miscChargeId String? @unique

  createdAt DateTime @default(now())

  rentNotice        RentNotice         @relation(fields: [rentNoticeId], references: [id], onDelete: Cascade)
  consumptionCharge ConsumptionCharge? @relation(fields: [consumptionChargeId], references: [id])
  miscCharge        MiscCharge?        @relation(fields: [miscChargeId], references: [id], onDelete: Restrict)

  @@index([rentNoticeId])
}

// Append-only krav-/leveranslogg för en hyresavi. Speglar InvoiceEvent: ingen
// updatedAt, Restrict mot avin → revisionsspåret kan aldrig raderas (BFL
// 1999:1078, append-only-principen 5 kap 5 §). Detta är dokumentationsstommen
// för "inkasso-ready": varje utskick, leveranskvittens, betalning, påminnelse,
// ränteackumulering och kravbeslut loggas här. PR 1 skapar tabellen; PR 2–5
// skriver händelser. Org-scopas via rentNotice.organizationId (ingen egen
// organizationId-kolumn behövs — avin äger relationen).
model RentNoticeEvent {
  id           String              @id @default(uuid())
  rentNoticeId String
  type         RentNoticeEventType

  // Aktör — vem/vad som utlöste händelsen (samma enum som InvoiceEvent).
  actorType  EventActorType
  actorId    String? // userId eller null för system/webhook
  actorLabel String? // Denormaliserat: "Anna Svensson" / "System" / "Resend"

  // Händelsespecifik data per typ, t.ex.
  //   { feeOre, journalEntryId } för REMINDER_SENT
  //   { throughDate, ratePercent, interestOre, journalEntryId } för INTEREST_ACCRUED
  //   { provider, messageId } för EMAIL_DELIVERED/BOUNCED
  payload Json @default("{}")

  // Immutabilitetsgaranti: ingen updatedAt.
  createdAt DateTime @default(now())

  rentNotice RentNotice @relation(fields: [rentNoticeId], references: [id], onDelete: Restrict)

  @@index([rentNoticeId, createdAt])
  @@index([rentNoticeId, type])
  @@index([createdAt])
  // OBS: Ett PARTIELLT unikt index på (rentNoticeId, type) WHERE type IN
  // ('EMAIL_DELIVERED','EMAIL_BOUNCED') finns i migrationen 20260607000000 men kan
  // INTE uttryckas i Prisma-schemat (partiella unika index saknar schema-syntax).
  // Det DB-enforce:ar idempotent leveranskorrelation (Resend at-least-once) utan
  // att hindra repeterbara event-typer (INTEREST_ACCRUED, REMINDER_SENT m.fl.).
}

// Bankavstämnings-härdning PR 1 — granulär betalningsallokering på en hyresavi.
//
// SYFTE: idag bär RentNotice bara en samlad paidAmount-cache + en @unique
// matchedRentNoticeId på BankTransaction. Det räcker inte för att resonera om
// DELbetalning, timing-glapp eller "zombie"-matchningar (se reconciliation/
// inkasso-riskanalysen). Den här tabellen gör betalningar GRANULÄRA: varje
// faktiskt registrerad betalning får en egen rad bredvid avin. Σ amount per avi
// är den auktoritativa "betalt"-summan; paidAmount blir en härledd spegel.
//
// PENGANEUTRAL: tabellen rör ALDRIG huvudboken. Verifikaten (JournalEntry) är
// räkenskapsinformationen och skapas/återförs precis som förr av AccountingService.
// Detta är ren härledd betalningsdata (BFL: stöd-/sidoordnad information), inte
// ett verifikat. Ingen status, inget utskick, inget kravbeslut skrivs här.
model RentNoticePayment {
  id           String @id @default(uuid())
  rentNoticeId String

  // Bank-transaktionen som gav upphov till allokeringen (BANK_RECONCILIATION).
  // NULL för manuell betalning (markAsPaid, source = MANUAL). @unique är PR 1:s
  // dubbel-allokeringsskydd: en bank-transaktion kan allokeras till EXAKT en avi
  // (ersätter BankTransaction.matchedRentNoticeId @unique). Postgres behandlar
  // NULL som distinkt i unika index → flera manuella allokeringar (NULL) kan
  // samexistera på samma eller olika avier utan kollision.
  bankTransactionId String? @unique

  // Allokerat belopp. Decimal(10,2) speglar avins penningfält. För
  // bankavstämning = den reglerade (betalbara) totalen; för markAsPaid = det
  // registrerade paidAmount. Σ amount per avi == paidAmount-spegeln (invariant
  // som backfillen och dual-write-testerna verifierar).
  amount Decimal @db.Decimal(10, 2)

  // Betalningsdatum (banktransaktionens datum, resp. markAsPaid:s paidAt).
  paidAt DateTime

  source RentNoticePaymentSource

  createdAt DateTime @default(now())

  rentNotice      RentNotice       @relation(fields: [rentNoticeId], references: [id], onDelete: Cascade)
  // onDelete: SetNull är explicit (matchar migrationens ON DELETE SET NULL och
  // Prisma-default för en nullbar relation — noll drift). En bank-transaktion är
  // räkenskapsinformation (Restrict mot org, raderas aldrig i praktiken); skulle
  // den ändå tas bort förblir allokeringen kvar med bankTransactionId = NULL i
  // stället för att blockera eller kaskadradera betalningsdata.
  bankTransaction BankTransaction? @relation(fields: [bankTransactionId], references: [id], onDelete: SetNull)

  @@index([rentNoticeId])
}

// Ursprunget för en betalningsallokering. BANK_RECONCILIATION = matchad mot en
// importerad bank-transaktion (OCR/referens/fuzzy/manuell matchning). MANUAL =
// registrerad via markAsPaid (ingen bank-transaktion).
enum RentNoticePaymentSource {
  BANK_RECONCILIATION
  MANUAL
}

