// ─── Platform (Super-admin SaaS) ──────────────────────────────────────────────

model PlatformUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  totpSecret   String?
  totpEnabled  Boolean   @default(false)
  lastLoginAt  DateTime?

  impersonationLogs ImpersonationLog[]
  refreshTokens     PlatformRefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// Refresh-tokens för super-admin. Lagras som SHA-256-hash (samma mönster
// som RefreshToken för tenants). Logout sätter revokedAt — token kan inte
// återanvändas. Cleanup-cron raderar utgångna rader.
model PlatformRefreshToken {
  id              String    @id @default(uuid())
  platformUserId  String
  token           String    @unique
  expiresAt       DateTime
  revokedAt       DateTime?

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([platformUserId])
  @@index([token])
  @@index([expiresAt])
}

model PlatformInvoice {
  id             String                @id @default(uuid())
  organizationId String
  invoiceNumber  String                @unique
  // Belopp INKL moms (Decimal måste matcha vad UI/PDF visar som totalt).
  // amountNetSek räknas baklänges som amount / 1.25.
  amount         Decimal               @db.Decimal(10, 2)
  status         PlatformInvoiceStatus @default(DRAFT)
  type           PlatformInvoiceType   @default(OTHER)
  description    String?
  dueDate        DateTime
  // För PLAN_FEE: vilken månad fakturan gäller (1:a → sista). Används i PDF.
  planPeriodStart DateTime?
  planPeriodEnd   DateTime?
  // Audit-tidsstämplar
  sentAt          DateTime?
  paidAt          DateTime?
  // Makulering (soft-delete, BFL 5 kap 11 § behandlingshistorik): en
  // plattformsfaktura raderas aldrig hårt utan makuleras (status VOID).
  // voidedAt/voidedReason gör makuleringen spårbar — vem/när/varför.
  voidedAt        DateTime?
  voidedReason    String?
  // Betalningsdetaljer (anges av Yasin när han markerar fakturan betald)
  // BANKGIRO | SWISH | MANUAL
  paymentMethod    String?
  paymentReference String?
  // Interna anteckningar — visas inte i PDF
  notes            String?
  // Antal påminnelser som skickats. Cron-jobb sätter; UI visar.
  reminderCount    Int @default(0)
  lastReminderAt   DateTime?
  // Senaste felmeddelandet från send() — sätts när auto-send (eller manuell
  // send) misslyckas, nollställs vid lyckat utskick. Gör att en faktura som
  // skapats men inte kunnat mailas kan felsökas och skickas om från UI.
  lastSendError    String?

  // Bokföringslagen (1999:1078): plattformsfakturor är räkenskapsinformation, bevaras 7 år.
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([type])
  @@index([dueDate])
  @@index([planPeriodStart])
}

model ImpersonationLog {
  id             String    @id @default(uuid())
  platformUserId String
  organizationId String
  targetUserId   String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  ipAddress      String?
  userAgent      String?
  reason         String?

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)
  // Revisionsspår: impersoneringsloggen måste bevaras vid org-borttagning (Restrict).
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  targetUser   User         @relation("ImpersonationTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId])
  @@index([organizationId])
  @@index([targetUserId])
  @@index([startedAt])
}

model ErrorLog {
  id             String        @id @default(uuid())
  organizationId String?
  severity       ErrorSeverity
  source         ErrorSource
  message        String        @db.Text
  stack          String?       @db.Text
  context        Json          @default("{}")
  resolved       Boolean       @default(false)
  resolvedAt     DateTime?

  // Revisionsspår: felloggen måste bevaras vid org-borttagning (Restrict).
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([organizationId, severity, resolved])
  @@index([createdAt])
}

// ─── Mail engine — failed-job DLQ ─────────────────────────────────────────────
// När en mailjobb har uttömt sina retries sparas det här för manuell inspektion
// och eventuell replay. Append-only — behandlas som event log.

model FailedEmail {
  id        String   @id @default(uuid())
  jobId     String
  template  String
  to        String
  subject   String
  payload   Json
  error     String   @db.Text
  attempts  Int
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([template])
}

// ─── Deposit (Deposition) ─────────────────────────────────────────────────────

enum DepositStatus {
  PENDING            // Fakturerad, ej betald
  PAID               // Betald, förvaras
  REFUND_PENDING     // Kontrakt avslutat, väntar återbetalning
  REFUNDED           // Återbetald fullt
  PARTIALLY_REFUNDED // Återbetald med avdrag
  FORFEITED          // Förverkad (skador översteg deposition)
}

model Deposit {
  id             String        @id @default(uuid())
  organizationId String
  leaseId        String        @unique
  tenantId       String
  amount         Decimal       @db.Decimal(10, 2)
  status         DepositStatus @default(PENDING)
  invoiceId      String?       @unique
  // #41: länk till aktiverings-avin (RentNotice{DEPOSIT}). En deposition betald
  // via avin spåras här; @unique = max en Deposit per avi. Alternativ till
  // invoiceId (manuella vägen) — en Deposit har antingen invoiceId ELLER
  // rentNoticeId beroende på hur den skapades. Gating i bankavstämningen kräver
  // en länkad Deposit innan en DEPOSIT-avi får matchas (fail-closed).
  rentNoticeId   String?       @unique
  paidAt         DateTime?
  refundedAt     DateTime?
  refundAmount   Decimal?      @db.Decimal(10, 2)
  deductions     Json?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Bokföringslagen (1999:1078): deposition/handpenning är räkenskapsinformation, bevaras 7 år.
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  lease        Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])
  rentNotice   RentNotice?  @relation(fields: [rentNoticeId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([tenantId])
}

// ─── RentIncrease (Hyreshöjning) ──────────────────────────────────────────────

enum RentIncreaseStatus {
  DRAFT       // Skapad men avisering ej skickad
  NOTICE_SENT // Avisering skickad till hyresgäst
  ACCEPTED    // Hyresgäst godkänt
  REJECTED    // Hyresgäst nekat
  WITHDRAWN   // Återkallad av hyresvärd
  APPLIED     // Den nya hyran har tillämpats på avtalet
  VOIDED      // Annullerad av systemet vid avtalsförnyelse (T1.3) — höjningen
              // pekade på det ersatta avtalet; registreras om på det nya
}

model RentIncrease {
  id              String             @id @default(uuid())
  organizationId  String
  leaseId         String
  currentRent     Decimal            @db.Decimal(10, 2)
  newRent         Decimal             @db.Decimal(10, 2)
  increasePercent Decimal             @db.Decimal(6, 2)
  reason          String
  noticeDate      DateTime?
  effectiveDate   DateTime           @db.Date
  status          RentIncreaseStatus @default(DRAFT)
  respondedAt     DateTime?
  rejectionReason String?
  // T1.3 audit-spår: när och varför höjningen annullerades vid succession —
  // "varför applicerades den aldrig?" ska kunna besvaras från raden själv.
  voidedAt        DateTime?
  voidReason      String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Bokföringslagen (1999:1078): hyreshöjningar är räkenskapsinformation, bevaras 7 år.
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  lease        Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([leaseId])
  @@index([status])
  @@index([effectiveDate])
}

// ─── KeyHandover (Nyckelkvittens) ─────────────────────────────────────────────
// Ren förvaltningsfunktion: spårar vilka fysiska nycklar/brickor som kvitterats
// ut till hyresgästen, när de lämnades ut och när de återlämnats. EN rad = EN
// fysisk nyckel (ingen quantity) → ren styckstatus och triviala "X av Y ute".
// Bulk-utlämning skapar N rader i en transaktion.
//
// Kopplingspunkt: Lease (precis som Deposit) — kvittensen tillhör hyresförhållandet,
// inte personen eller väggen. unitId + tenantId denormaliseras för filtrering/vy
// (samma mönster som Deposit bär både leaseId och tenantId).
//
// Append-only-etos: en återlämnad nyckel RADERAS aldrig — returnedAt sätts och
// status → RETURNED. Posterna är bevis vid depositionstvist (jfr § 6 i kontraktet:
// deposition återbetalas "mot kvitterad återlämning av samtliga nycklar").

enum KeyType {
  APARTMENT // Lägenhets-/lokalnyckel
  ENTRANCE // Port-/entrényckel
  MAILBOX // Postboxnyckel
  LAUNDRY_TAG // Tvättstugebricka/-tagg
  GARAGE // Garage-/parkeringsnyckel
  STORAGE // Förråds-/vindsnyckel
  FOB_TAG // Passerbricka/tagg
  OTHER // Övrigt
}

enum KeyStatus {
  ISSUED // Utlämnad, ej återlämnad
  RETURNED // Återlämnad
  LOST // Förlorad/borttappad
  REPLACED // Ersatt (t.ex. omkodad efter förlust)
}

model KeyHandover {
  id             String    @id @default(uuid())
  organizationId String
  leaseId        String
  unitId         String
  tenantId       String
  type           KeyType
  label          String? // Märkning/serienr, t.ex. "Nyckel A / 4471"
  status         KeyStatus @default(ISSUED)
  issuedAt       DateTime  @default(now())
  issuedToName   String? // Om annan än hyresgästen fysiskt kvitterade (sambo/firma)
  issuedById     String? // User som lämnade ut
  returnedAt     DateTime?
  receivedById   String? // User som tog emot återlämningen
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // organization: Restrict — nyckelkvittenser är bevis, raderas inte med org.
  // lease: Cascade — speglar Deposit; en force-raderad (DRAFT) lease städar sina rader.
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  lease        Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  unit         Unit         @relation(fields: [unitId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  @@index([organizationId])
  @@index([leaseId])
  @@index([unitId])
  @@index([tenantId])
  @@index([status])
}

// ─── IMD – förbrukningsdebitering (el/vatten/värme) ───────────────────────────
// Individuell mätning och debitering. Fyra entiteter med strikt ansvarsdelning:
//   Meter             — fysisk mätare, sitter på enheten (väggen), inte lease:n.
//   MeterReading      — append-only mätunderlag (BFL 7 år), källagnostiskt.
//   ConsumptionTariff — prismodell med historik (validFrom/validTo).
//   ConsumptionCharge — den debiterbara, prissatta och moms-snapshotade posten.
//
// PR 1 = ren persistens. Inget läser/skriver dessa ännu; intake (PR 2),
// bokföring (PR 3), leveranssätt (PR 4) och bokslut (PR 5) bygger ovanpå.
//
// Momsfrågor som ännu är öppna (konsult): docs/legal/45-imd-forbrukningsdebitering-momsfragor.md

enum MeterType {
  ELECTRICITY // El (kWh) → intäktskonto 3920
  WATER_COLD // Kallvatten (m³) → 3970
  WATER_HOT // Varmvatten (m³) → 3970 (öppen momsfråga 2)
  HEATING // Värme (kWh/MWh) → 3920
}

enum MeterStatus {
  ACTIVE // I drift, avläses
  INACTIVE // Tillfälligt ur bruk
  REMOVED // Demonterad (behålls för historik – readings finns kvar)
}

// Hur en avläsning levererades. ALLA tre går genom SAMMA recordReading()-tjänst
// (PR 2) — manuell input och framtida leverantörs-API delar väg.
enum ReadingSource {
  MANUAL // Inmatad av handläggare
  IMPORT // Fil-/CSV-import
  API // Leverantörs-API (framtid)
}

// Värdetyp på avläsningen. CUMULATIVE = mätarställning (förbrukning beräknas som
// differens mot föregående avläsning — default, självläker vid missad period).
// PERIOD_VOLUME = färdig periodförbrukning ("240 kWh i maj").
enum ReadingType {
  CUMULATIVE
  PERIOD_VOLUME
}

enum ConsumptionChargeStatus {
  DRAFT // Skapad och prissatt, ej bokförd (PR 2)
  CONFIRMED // Periodiserat verifikat + 1510-fordran bokförd (PR 3)
  ATTACHED // Kopplad till avi/faktura för presentation + betalning (PR 4)
  CANCELLED // Annullerad (rättning – posterna raderas aldrig)
}

// ACTUAL i v1. ESTIMATE/ADJUSTMENT-sömmen behålls för framtida schablon och
// bokslutspost (PR 5) utan migrationssmärta — ingen schablon byggs i v1.
enum ConsumptionChargeKind {
  ACTUAL
  ESTIMATE
  ADJUSTMENT
}

// Momsstatus snapshotad på charge:n från lease/unit-konfiguration vid skapande.
// EXEMPT default för bostad (ML 3 kap 2 §). Regeln spikas ALDRIG i kod — läses
// från konfiguration. Se öppen momsfråga 1 om SEPARATE_INVOICE.
enum ConsumptionVatStatus {
  EXEMPT
  TAXABLE_25
}

// Leveranssätt — konfiguration per fastighet (default) och lease (override).
// Default RENT_NOTICE_LINE (det momssäkra fallet).
enum ConsumptionBillingMode {
  RENT_NOTICE_LINE // Rad på hyresavin (ett OCR, en betalning)
  SEPARATE_INVOICE // Egen faktura (Invoice, type=UTILITY)
  NONE // Ingen förbrukningsdebitering
}

// Tariffens räckvidd. ORGANIZATION = standardpris; PROPERTY/UNIT = mer specifik
// åsidosätter bredare (löses i intake-tjänsten, PR 2).
enum TariffScope {
  ORGANIZATION
  PROPERTY
  UNIT
}

model Meter {
  id             String      @id @default(uuid())
  organizationId String
  unitId         String
  type           MeterType
  unitOfMeasure  String // "kWh" | "m³" — fri text, källagnostisk
  serialNumber   String?
  status         MeterStatus @default(ACTIVE)

  // Källagnostik: extern koppling för framtida leverantörs-API. provider +
  // externalId identifierar mätaren hos datakällan; intake matchar på dessa.
  provider   String?
  externalId String?

  installedAt DateTime?
  removedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Restrict mot org OCH unit: mätaren bär räkenskapsinformation via sina
  // avläsningar (BFL 7 år) — en enhet/org med mätare raderas inte tyst.
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  unit         Unit           @relation(fields: [unitId], references: [id], onDelete: Restrict)
  readings     MeterReading[]

  @@index([organizationId])
  @@index([unitId])
  @@index([status])
}

model MeterReading {
  id             String        @id @default(uuid())
  organizationId String
  meterId        String
  // Denormaliserat arkiv (speglar Deposit/KeyHandover): självständigt underlag
  // som överlever om-/avkoppling av lease. leaseId är en historisk ögonblicks-
  // bild (vilken lease som var aktiv vid avläsningen) — plain string, ingen FK,
  // så att en lease-radering aldrig blockeras av eller nollar mätunderlaget.
  unitId         String
  leaseId        String?
  value          Decimal       @db.Decimal(14, 3)
  readingType    ReadingType   @default(CUMULATIVE)
  readingDate    DateTime // När mätaren lästes
  periodStart    DateTime      @db.Date // Mätperiodens start (skild från fakturadatum)
  periodEnd      DateTime      @db.Date // Mätperiodens slut — styr räkenskapsåret
  source         ReadingSource
  externalId     String? // Datakällans avläsnings-id → idempotens vid API-ingest
  registeredById String? // User vid MANUAL
  notes          String?

  // Append-only (BFL 5 kap 5 §): INGEN updatedAt. Rättning = ny rad, aldrig UPDATE/DELETE.
  createdAt DateTime @default(now())

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  meter        Meter               @relation(fields: [meterId], references: [id], onDelete: Restrict)
  charges      ConsumptionCharge[]

  // Idempotens för API-/import-ingest: samma (mätare, externt avläsnings-id) får
  // inte skapa två rader. MANUAL har null externalId → ej begränsad.
  @@unique([meterId, externalId])
  @@index([organizationId])
  @@index([meterId])
  @@index([periodEnd])
}

model ConsumptionTariff {
  id             String      @id @default(uuid())
  organizationId String
  scope          TariffScope @default(ORGANIZATION)
  // Scope-mål (polymorft): PROPERTY → propertyId satt; UNIT → unitId satt;
  // ORGANIZATION → båda null. Plain strings (ingen FK) eftersom en tariff kan
  // peka på ettdera och upplösningen sker i intake-tjänsten (PR 2).
  propertyId     String?
  unitId         String?
  meterType      MeterType
  pricePerUnit   Decimal     @db.Decimal(10, 4)
  fixedMonthlyFee Decimal?   @db.Decimal(10, 2)

  // Beräkningsgrund (JB 12:19): fri dokumentationstext om hur vidaredebiteringen
  // beräknas — underlag som hyresnämnden kan begära. ENBART dokumentation, ingår
  // ALDRIG i någon charge-/bokföringsberäkning.
  calculationBasis String?

  // Historik: validTo = null är gällande tariff. Pris uppdateras ALDRIG
  // in-place — ny rad ersätter och stänger föregående. Avläsningens periodEnd
  // väljer den tariff som gällde då.
  validFrom DateTime  @db.Date
  validTo   DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([meterType])
  @@index([scope])
}

model ConsumptionCharge {
  id             String @id @default(uuid())
  organizationId String
  leaseId        String
  // Denormaliserat (speglar Deposit som bär leaseId+tenantId): självständigt underlag.
  unitId         String
  tenantId       String
  meterReadingId String
  meterType      MeterType

  periodStart  DateTime @db.Date
  periodEnd    DateTime @db.Date // Styr verifikatets datum (periodisering, PR 3)
  quantity     Decimal  @db.Decimal(14, 3)
  pricePerUnit Decimal  @db.Decimal(10, 4)
  netAmount    Decimal  @db.Decimal(10, 2)

  // Moms = snapshot från lease/unit-config vid skapande. EXEMPT default bostad.
  // Regeln spikas aldrig i kod (se öppen momsfråga 1).
  vatStatus   ConsumptionVatStatus @default(EXEMPT)
  vatRate     Int                  @default(0)
  vatAmount   Decimal              @default(0) @db.Decimal(10, 2)
  totalAmount Decimal              @db.Decimal(10, 2)

  kind         ConsumptionChargeKind   @default(ACTUAL)
  status       ConsumptionChargeStatus @default(DRAFT)
  // Leveranssätt snapshotat vid skapande — presentation, ej bokföring.
  deliveryMode ConsumptionBillingMode  @default(RENT_NOTICE_LINE)

  // Var posten landade (sätts vid ATTACHED, PR 4). Rad-på-avi via RentNoticeLine
  // (1:1, FK på line-sidan); separat faktura via invoiceId (många charges → en faktura).
  invoiceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Restrict mot org OCH lease — charges är bevis (striktare än Deposit, som har
  // Cascade mot lease). meterReading Restrict: underlaget får inte försvinna.
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  lease          Lease           @relation(fields: [leaseId], references: [id], onDelete: Restrict)
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  meterReading   MeterReading    @relation(fields: [meterReadingId], references: [id], onDelete: Restrict)
  invoice        Invoice?        @relation(fields: [invoiceId], references: [id])
  rentNoticeLine RentNoticeLine?

  @@index([organizationId])
  @@index([leaseId])
  @@index([status])
  @@index([periodEnd])
}

// ─── Teknisk förvaltning: övrig debiterbar post (Spår A) ──────────────────────
//
// Generisk intäkts-charge mot hyresgäst för teknisk förvaltning (skada från
// felanmälan, nyckelersättning m.m.). Speglar ConsumptionCharge:ns konventioner
// (denormaliserade scope-kolumner som självständigt underlag, Restrict mot org +
// lease eftersom charges är bevis, status-/moms-snapshot). SKILD från
// ConsumptionCharge för att inte förorena mätar-semantiken (meterReadingId är
// där NOT NULL; en skada/nyckel har inget mätunderlag) — beslut "Väg 2",
// specialist-granskningen 2026-06-24.
//
// PR 1 (denna): BARA datamodellen + scope-kolumner. INGEN bokföringslogik, ingen
// debiterings-service, ingen frontend. Bokföring (1510 D / 3040|3990 K) sker i
// PR 2/3 via AccountingService med source=MISC_CHARGE, sourceId='misc-charge:{id}'.
model MiscCharge {
  id String @id @default(uuid())

  // Denormaliserade scope-kolumner som EGNA fält (speglar ConsumptionCharge:
  // "självständigt underlag") — scopas ALDRIG via JOIN. unitId/invoiceId
  // medvetet utelämnade i PR 1 (invoiceId hör till attach, PR 4).
  organizationId String
  leaseId        String
  tenantId       String

  // Källa som METADATA (ej polymorf FK uppåt). Den hårda FK:n ligger på
  // källmodellen (t.ex. MaintenanceTicket.chargeId). sourceType/sourceRefId är
  // den generiska kopplingen som framtida källor (INSPECTION_ITEM, KEY_LOSS)
  // använder utan egen FK. Se AVSIKTLIG DUBBELLÄNK-kommentaren i MaintenanceTicket.
  sourceType  MiscChargeSource
  sourceRefId String

  description String
  // Bokföringsdatum (PR 2): när skadan/förlusten konstaterades — INTE createdAt
  // (fel räkenskapsår). Speglar ConsumptionCharge.periodEnd som verifikatets datum.
  incidentDate DateTime @db.Date

  // Money — speglar ConsumptionCharge. vatStatus EXEMPT default (bostad, ML 3:2);
  // momsbeslutet spikas ALDRIG i kod, dokumenteras i PR 2. Belopp är snapshots —
  // frontend räknar aldrig om dem.
  netAmount   Decimal             @db.Decimal(10, 2)
  vatStatus   MiscChargeVatStatus @default(EXEMPT)
  vatRate     Int                 @default(0)
  vatAmount   Decimal             @default(0) @db.Decimal(10, 2)
  totalAmount Decimal             @db.Decimal(10, 2)

  // DRAFT default — bokförs först i PR 2/3. TODO PR 4: ATTACHED får sättas FÖRST
  // när posten kopplats till avi/faktura (invoiceId/RentNoticeLine). Ingen kod i
  // PR 1 får sätta status=ATTACHED — invoiceId-fältet och attach-flödet finns ännu inte.
  status MiscChargeStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Restrict mot org OCH lease — charges är bevis (speglar ConsumptionCharge,
  // striktare än Deposit som har Cascade mot lease). tenant utan Restrict (spegel).
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  lease        Lease        @relation(fields: [leaseId], references: [id], onDelete: Restrict)
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  // Back-relations (1:1) — den hårda FK:n med onDelete: Restrict ligger på
  // motpartssidan (MaintenanceTicket.chargeId, RentNoticeLine.miscChargeId).
  maintenanceTicket MaintenanceTicket?
  rentNoticeLine    RentNoticeLine?

  @@index([organizationId])
  @@index([leaseId])
  @@index([status])
  @@index([sourceType, sourceRefId])
}

enum MiscChargeStatus {
  DRAFT // Skapad och prissatt, ej bokförd (PR 2)
  CONFIRMED // Verifikat + 1510-fordran bokförd (PR 3)
  ATTACHED // Kopplad till avi/faktura för presentation + betalning (PR 4)
  CANCELLED // Annullerad (rättning – posterna raderas aldrig)
}

// Momsstatus snapshotad från lease/unit-konfiguration vid skapande. EXEMPT
// default för bostad (ML 3 kap 2 §). Regeln spikas ALDRIG i kod — momsbeslutet
// dokumenteras i PR 2.
enum MiscChargeVatStatus {
  EXEMPT
  TAXABLE_25
}

// Källtyp för den debiterbara posten. MAINTENANCE_TICKET i v1 (felanmälan →
// debitering). INSPECTION_ITEM/KEY_LOSS finns i sömmen för Spår A område 2–3
// utan migrationssmärta — ingen logik för dem byggs i v1.
enum MiscChargeSource {
  MAINTENANCE_TICKET
  INSPECTION_ITEM
  KEY_LOSS
}

// ─── Juridik-RAG: semantisk sökning (Etapp 3) ─────────────────────────────────

/// Lagrad Voyage-embedding per paragraf-chunk i den verifierade lagtexten.
///
/// GLOBAL/PUBLIK — INTE org-scopad. Lagtext (LEGAL_KNOWLEDGE) är publik och delas
/// av alla organisationer; ingen relation till Organization/Tenant och ingen
/// personuppgift förekommer här. Tabellen är retrieval-infrastruktur, inte domän.
///
/// Etapp 3, PR 3.1: BARA lagringen. Tabellen är TOM efter denna migration —
/// vektorerna fylls av indexerings-scriptet i PR 3.2 (`knowledge:embed`), som är
/// den första (och enda) plats som anropar Voyage. Inget embeddas här.
///
/// Idempotens (PR 3.2): `contentHash` (sha256 av chunk-texten) gör omindexering
/// billig — bara chunkar vars text ändrats behöver embeddas om. `model` spårar
/// vilken Voyage-modell vektorn kommer från, så ett modellbyte är upptäckbart.
model LegalChunkEmbedding {
  /// Stabil PK = `lawId:paragraph` (t.ex. "hyreslagen:54 a"). Samma nyckel som
  /// buildLegalChunks() härleder ur LEGAL_KNOWLEDGE — joinen mellan runtime-text
  /// och lagrad vektor i PR 3.3.
  id String @id

  /// Spårbarhet — speglar LegalChunk-metadatan (källa: LEGAL_KNOWLEDGE).
  lawId     String
  paragraph String
  sfs       String

  /// sha256 av chunkens fulltext. Idempotensnyckel för PR 3.2:s omindexering.
  contentHash String

  /// 1024-dim Voyage-embedding (voyage-law-2/voyage-3). Unsupported: Prisma har
  /// ingen native vector-typ — kolumnen skapas av migrationen, läses via
  /// $queryRaw i PR 3.3. HNSW-indexet läggs som rå SQL i migrationen (Prisma kan
  /// inte generera @@index på en Unsupported-kolumn).
  embedding Unsupported("vector(1024)")

  /// Voyage-modellen vektorn genererades med, t.ex. "voyage-law-2".
  model String

  createdAt DateTime @default(now())

  @@index([lawId])
}
