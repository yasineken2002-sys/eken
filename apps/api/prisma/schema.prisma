generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  ACCOUNTANT
  VIEWER
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  MIXED
  INDUSTRIAL
  LAND
}

enum UnitType {
  APARTMENT
  OFFICE
  RETAIL
  STORAGE
  PARKING
  OTHER
}

enum UnitStatus {
  VACANT
  OCCUPIED
  UNDER_RENOVATION
  RESERVED
}

enum TenantType {
  INDIVIDUAL
  COMPANY
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  TERMINATED
  EXPIRED
}

enum LeaseType {
  FIXED_TERM
  INDEFINITE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
  SENT_TO_COLLECTION
}

enum PaymentReminderType {
  REMINDER_FRIENDLY
  REMINDER_FORMAL
  READY_FOR_COLLECTION
}

enum InvoiceType {
  RENT
  DEPOSIT
  SERVICE
  UTILITY
  OTHER
}

// PDF-mallvalet för fakturor – styr layouten i invoice-pdf.template.ts.
// Lowercase-värden så befintliga rader ('classic', 'modern', 'minimal')
// kan migreras direkt utan UPDATE.
enum InvoiceTemplate {
  classic
  modern
  minimal
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntrySource {
  MANUAL
  INVOICE
  PAYMENT
  LEASE
}

// ─── Invoice Event Types ──────────────────────────────────────────────────────
// Append-only audit log för fakturahistorik.
// Samma mönster som Fortnox, Visma och Stripe.

enum InvoiceEventType {
  // Livscykel
  CREATED
  UPDATED
  // Utskick
  SENT
  SEND_FAILED
  // E-postleverans (provider-webhook)
  EMAIL_QUEUED
  EMAIL_DELIVERED
  EMAIL_BOUNCED
  EMAIL_SPAM
  // Mottagaraktivitet
  EMAIL_OPENED
  PDF_VIEWED
  // Betalning
  PAYMENT_RECEIVED
  PAYMENT_PARTIAL
  PAYMENT_REVERSED
  // Förfallen-flöde
  OVERDUE
  REMINDER_SENT
  DEBT_COLLECTION
  // Korrigeringar
  VOIDED
  CREDIT_NOTE_CREATED
  // Administrativt
  NOTE_ADDED
  VIEWED_BY_USER
}

enum EventActorType {
  USER
  SYSTEM
  WEBHOOK
}

enum BankTransactionStatus {
  UNMATCHED
  MATCHED
  IGNORED
}

enum ImportJobType {
  PROPERTIES
  UNITS
  TENANTS
  LEASES
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MaintenanceStatus {
  NEW
  IN_PROGRESS
  SCHEDULED
  COMPLETED
  CLOSED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  HEATING
  APPLIANCES
  WINDOWS_DOORS
  LOCKS
  FACADE
  ROOF
  COMMON_AREAS
  CLEANING
  OTHER
}

enum MessageStatus {
  SENT
  FAILED
  PARTIAL
}

enum RentNoticeStatus {
  PENDING
  SENT
  PAID
  OVERDUE
  CANCELLED
  FAILED
}

enum InspectionType {
  MOVE_IN
  MOVE_OUT
  PERIODIC
  DAMAGE
}

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  SIGNED
}

enum InspectionItemCondition {
  GOOD
  ACCEPTABLE
  DAMAGED
  MISSING
}

enum MaintenancePlanStatus {
  PLANNED
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenancePlanCategory {
  ROOF
  FACADE
  WINDOWS
  PLUMBING
  ELECTRICAL
  HEATING
  ELEVATOR
  COMMON_AREAS
  PAINTING
  FLOORING
  OTHER
}

enum DocumentCategory {
  CONTRACT
  INSPECTION
  DRAWING
  PHOTO
  INVOICE
  INSURANCE
  OTHER
