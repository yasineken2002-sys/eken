generator client {
  provider = "prisma-client-js"
  // omitApi: tillåter `omit: { … }` i queries för att utelämna känsliga skalärfält
  // från svaret (t.ex. interna R2-nycklar/message-id som aldrig ska nå klienten).
  // GA i Prisma 6.2; preview på 5.22. Additiv — påverkar inga befintliga queries.
  // postgresqlExtensions: låter Prisma äga pgvector-extensionen i datasource
  // (CREATE EXTENSION vector genereras i migrationen). Krävs för Etapp 3:s
  // semantiska sökning (LegalChunkEmbedding.embedding = vector(1024)).
  previewFeatures = ["omitApi", "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // pgvector — lagring av Voyage-embeddings för juridik-RAG:ens semantiska
  // sökning (Etapp 3). Extensionen tillhandahålls av pgvector/pgvector:pg16.
  extensions = [vector]
}

