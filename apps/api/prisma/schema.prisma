// ─── Rent Notice (Hyresavi) ───────────────────────────────────────────────────

model RentNotice {
  id             String           @id @default(uuid())
  organizationId String
  tenantId       String
  leaseId        String
  noticeNumber   String
  ocrNumber      String
  month          Int
  year           Int
  amount         Decimal          @db.Decimal(10, 2)
  vatAmount      Decimal          @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal          @db.Decimal(10, 2)
  dueDate        DateTime
  paidAt         DateTime?
  paidAmount     Decimal?         @db.Decimal(10, 2)
  // Betalningssätt vid manuell betalningsregistrering (markAsPaid). Nullbar:
  // historiska/obetalda avier saknar värde, och bankavstämda betalningar
  // (reconciliation) sätter det inte. Styr debetkontot i betalningsverifikatet.
  paymentMethod  PaymentMethod?
  status         RentNoticeStatus @default(PENDING)
  sentAt         DateTime?
  sentTo         String?
  sendError      String?

  // ── Typ + proportionell hyra (delmånad) ─────────────────────────────────
  // type skiljer ren månadshyra från deposition. Periodfälten används av
  // PDF-mallen för att visa "9 maj – 31 maj (23/31 dagar)".
  type        RentNoticeType @default(RENT)
  periodStart DateTime?      @db.Date
  periodEnd   DateTime?      @db.Date
  daysCharged Int?
  totalDays   Int?
  isProrated  Boolean        @default(false)

  // Bokföringslagen (1999:1078): hyresavier är räkenskapsinformation, bevaras 7 år.
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  lease            Lease             @relation(fields: [leaseId], references: [id])
  bankTransactions BankTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Idempotency på (lease, period, typ) — samma månad får INTE generera två
  // RENT-avier eller två DEPOSIT-avier. Det gamla unique på (org,tenant,month,
  // year) räcker inte när tenant har flera kontrakt eller när vi även lagrar
  // DEPOSIT i samma tabell.
  @@unique([leaseId, year, month, type])
  // H1: avinummer är unikt PER ORGANISATION, inte globalt. Det gamla globala
  // @unique på noticeNumber gjorde att två orgar inte kunde dela samma
  // AVI-2026-06-0001. Den composite unique:n indexerar även (organizationId,
  // noticeNumber) → nextNoticeNumber-prefixsökningen slipper full table scan.
  @@unique([organizationId, noticeNumber])
  @@index([organizationId])
  @@index([status])
  @@index([dueDate])
  @@index([leaseId])
}

