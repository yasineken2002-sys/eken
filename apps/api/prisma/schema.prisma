// Avi-typ. RENT är vanlig månadshyresavi (kan vara delmånad), DEPOSIT är
// engångsavin för deposition vid lease-aktivering. Andra typer (extra-debet
// för skadestånd, indexhöjningar etc.) kan läggas till senare utan
// migrationssmärta.
enum RentNoticeType {
  RENT
  DEPOSIT
}

// Betalningssätt vid manuell betalningsregistrering av en hyresavi
// (markAsPaid). Styr vilket BAS-tillgångskonto som debiteras när
// kundfordran (1510) regleras:
//   BANK   → 1930 Företagskonto
//   CASH   → 1910 Kassa
//   SWISH  → 1930 Företagskonto (Swish landar på företagskontot; sättet sparas
//            ändå här för audit/statistik och i verifikatets radtext)
//   MANUAL → 1930 (okänt/övrigt sätt — bokförs konservativt mot bankkontot)
enum PaymentMethod {
  BANK
  CASH
  SWISH
  MANUAL
}

enum InspectionType {
  MOVE_IN
  MOVE_OUT
  PERIODIC
  DAMAGE
}

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
