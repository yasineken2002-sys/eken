generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  ACCOUNTANT
  VIEWER
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  MIXED
  INDUSTRIAL
  LAND
}

enum UnitType {
  APARTMENT
  OFFICE
  RETAIL
  STORAGE
  PARKING
  OTHER
}

enum UnitStatus {
  VACANT
  OCCUPIED
  UNDER_RENOVATION
  RESERVED
}

enum TenantType {
  INDIVIDUAL
  COMPANY
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  TERMINATED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum InvoiceType {
  RENT
  DEPOSIT
  SERVICE
  UTILITY
  OTHER
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntrySource {
  MANUAL
  INVOICE
  PAYMENT
  LEASE
}

// ─── Invoice Event Types ──────────────────────────────────────────────────────
// Append-only audit log för fakturahistorik.
// Samma mönster som Fortnox, Visma och Stripe.

enum InvoiceEventType {
  // Livscykel
  CREATED
  UPDATED
  // Utskick
  SENT
  SEND_FAILED
  // E-postleverans (provider-webhook)
  EMAIL_QUEUED
  EMAIL_DELIVERED
  EMAIL_BOUNCED
  EMAIL_SPAM
  // Mottagaraktivitet
  EMAIL_OPENED
  PDF_VIEWED
  // Betalning
  PAYMENT_RECEIVED
  PAYMENT_PARTIAL
  PAYMENT_REVERSED
  // Förfallen-flöde
  OVERDUE
  REMINDER_SENT
  DEBT_COLLECTION
  // Korrigeringar
  VOIDED
  CREDIT_NOTE_CREATED
  // Administrativt
  NOTE_ADDED
  VIEWED_BY_USER
}

enum EventActorType {
  USER
  SYSTEM
  WEBHOOK
}

enum BankTransactionStatus {
  UNMATCHED
  MATCHED
  IGNORED
}

enum ImportJobType {
  PROPERTIES
  UNITS
  TENANTS
  LEASES
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DocumentCategory {
  CONTRACT
  INSPECTION
  DRAWING
  PHOTO
  INVOICE
  INSURANCE
  OTHER
}

// ─── Organization (Tenant in multi-tenant context) ────────────────────────────

model Organization {
  id          String  @id @default(uuid())
  name        String
  orgNumber   String  @unique
  vatNumber   String?
  email       String
  phone       String?
  street      String
  city        String
  postalCode  String
  country     String  @default("SE")
  logoUrl              String?
  bankgiro             String?
  paymentTermsDays     Int     @default(30)
  invoiceColor         String?
  invoiceTemplate      String?
  morningReportEnabled Boolean @default(false)

  users             User[]
  properties        Property[]
  tenants           Tenant[]
  invoices          Invoice[]
  accounts          Account[]
  journalEntries    JournalEntry[]
  bankTransactions  BankTransaction[]
  documents         Document[]
  importJobs        ImportJob[]
  aiConversations   AiConversation[]
  aiMemories        AiMemory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgNumber])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  organizationId String
  email          String   @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole @default(VIEWER)
  avatarUrl      String?
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens   RefreshToken[]
  journalEntries  JournalEntry[]
  documents       Document[]
  importJobs      ImportJob[]
  aiConversations AiConversation[]
  aiMemories      AiMemory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ─── Property (Fastighet) ─────────────────────────────────────────────────────

model Property {
  id                     String       @id @default(uuid())
  organizationId         String
  name                   String
  propertyDesignation    String
  type                   PropertyType
  street                 String
  city                   String
  postalCode             String
  country                String       @default("SE")
  totalArea              Decimal      @db.Decimal(10, 2)
  yearBuilt              Int?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  units        Unit[]
  documents    Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// ─── Unit (Lägenhet/Lokal) ────────────────────────────────────────────────────

model Unit {
  id          String     @id @default(uuid())
  propertyId  String
  name        String
  unitNumber  String
  type        UnitType
  status      UnitStatus @default(VACANT)
  area        Decimal    @db.Decimal(10, 2)
  floor       Int?
  rooms       Int?
  monthlyRent Decimal    @db.Decimal(10, 2)

  property  Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases    Lease[]
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propertyId, unitNumber])
  @@index([propertyId])
  @@index([status])
}

// ─── Tenant (Hyresgäst) ───────────────────────────────────────────────────────

model Tenant {
  id             String     @id @default(uuid())
  organizationId String
  type           TenantType
  firstName      String?
  lastName       String?
  personalNumber String?
  companyName    String?
  orgNumber      String?
  contactPerson  String?
  email          String
  phone          String?
  street         String?
  city           String?
  postalCode     String?
  country        String?    @default("SE")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leases       Lease[]
  invoices     Invoice[]
  documents    Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
}

// ─── Lease (Hyresavtal) ───────────────────────────────────────────────────────

model Lease {
  id                 String      @id @default(uuid())
  organizationId     String
  unitId             String
  tenantId           String
  status             LeaseStatus @default(DRAFT)
  startDate          DateTime    @db.Date
  endDate            DateTime?   @db.Date
  monthlyRent        Decimal     @db.Decimal(10, 2)
  depositAmount      Decimal     @db.Decimal(10, 2)
  noticePeriodMonths Int         @default(3)
  indexClause        Boolean     @default(false)
  signedAt           DateTime?
  terminatedAt       DateTime?
  terminationReason  String?

  unit      Unit       @relation(fields: [unitId], references: [id])
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  invoices  Invoice[]
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([unitId])
  @@index([tenantId])
  @@index([status])
}

// ─── Invoice (Faktura) ────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  organizationId String
  invoiceNumber  String
  type           InvoiceType
  status         InvoiceStatus @default(DRAFT)
  tenantId       String
  leaseId        String?
  subtotal       Decimal       @db.Decimal(10, 2)
  vatTotal       Decimal       @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  dueDate        DateTime      @db.Date
  issueDate      DateTime      @db.Date
  paidAt         DateTime?
  reference      String?
  notes          String?

  // Tracking-token för e-postspårning (pixel + PDF-länk)
  // Genereras vid skapande, används aldrig om – en faktura, ett token.
  trackingToken  String        @unique @default(uuid())

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  lease            Lease?            @relation(fields: [leaseId], references: [id])
  lines            InvoiceLine[]
  events           InvoiceEvent[]
  bankTransactions BankTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([tenantId])
  @@index([status])
  @@index([dueDate])
  @@index([trackingToken])
}

// ─── Invoice Event Log ────────────────────────────────────────────────────────
// Immutabel append-only tabell. Inga UPDATE, inga DELETE (utom via Cascade).
// Svensk bokföringslag kräver 7 års retention – soft-delete vid org-borttagning.

model InvoiceEvent {
  id          String           @id @default(uuid())
  invoiceId   String
  type        InvoiceEventType

  // Aktör – vem/vad som utlöste händelsen
  actorType   EventActorType
  actorId     String?          // userId eller null för system/webhook
  actorLabel  String?          // Denormaliserat: "Anna Svensson" / "System" / "Postmark"

  // Händelsespecifik data – flexibel JSON per händelsetyp
  // t.ex. { email, provider, messageId } för e-postleverans
  // t.ex. { amount, paymentMethod, reference } för betalning
  // t.ex. { previousStatus, newStatus } för statusövergång
  payload     Json             @default("{}")

  // E-postspårnings-metadata
  ipAddress   String?
  userAgent   String?

  // Immutabilitetsgaranti: ingen updatedAt
  createdAt   DateTime         @default(now())

  invoice     Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Komposit-index för tidslinjequery (en faktura, sorterat på tid)
  @@index([invoiceId, createdAt])
  // Index för filtrering per händelsetyp
  @@index([invoiceId, type])
  // Index för global aktivitetsfeed
  @@index([createdAt])
}

model InvoiceLine {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(10, 4)
  unitPrice   Decimal @db.Decimal(10, 2)
  vatRate     Int
  total       Decimal @db.Decimal(10, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─── Accounting ───────────────────────────────────────────────────────────────

model Account {
  id             String      @id @default(uuid())
  organizationId String
  number         Int
  name           String
  type           AccountType
  parentId       String?
  isActive       Boolean     @default(true)

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         Account?           @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       Account[]          @relation("AccountHierarchy")
  journalLines   JournalEntryLine[]

  @@unique([organizationId, number])
  @@index([organizationId])
}

model JournalEntry {
  id             String             @id @default(uuid())
  organizationId String
  date           DateTime           @db.Date
  description    String
  reference      String?
  source         JournalEntrySource @default(MANUAL)
  sourceId       String?
  createdById    String

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User               @relation(fields: [createdById], references: [id])
  lines        JournalEntryLine[]

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([date])
}

model JournalEntryLine {
  id             String   @id @default(uuid())
  journalEntryId String
  accountId      String
  debit          Decimal? @db.Decimal(10, 2)
  credit         Decimal? @db.Decimal(10, 2)
  description    String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

// ─── Bank Reconciliation (Bankavstämning) ─────────────────────────────────────

model BankTransaction {
  id             String                @id @default(uuid())
  organizationId String
  date           DateTime
  description    String
  amount         Decimal               @db.Decimal(12, 2)
  balance        Decimal?              @db.Decimal(12, 2)
  reference      String?
  rawOcr         String?
  status         BankTransactionStatus @default(UNMATCHED)
  invoiceId      String?
  matchedAt      DateTime?
  matchedBy      String?
  createdAt      DateTime              @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([invoiceId])
}

// ─── Document (Dokumentarkiv) ─────────────────────────────────────────────────

model Document {
  id             String           @id @default(uuid())
  organizationId String
  name           String
  description    String?
  fileUrl        String
  fileSize       Int
  mimeType       String
  category       DocumentCategory @default(OTHER)
  propertyId     String?
  unitId         String?
  leaseId        String?
  tenantId       String?
  uploadedById   String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property?    @relation(fields: [propertyId], references: [id])
  unit         Unit?        @relation(fields: [unitId], references: [id])
  lease        Lease?       @relation(fields: [leaseId], references: [id])
  tenant       Tenant?      @relation(fields: [tenantId], references: [id])
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([propertyId])
  @@index([unitId])
  @@index([leaseId])
  @@index([tenantId])
}

// ─── AI Assistant ─────────────────────────────────────────────────────────────

model AiConversation {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  title          String   @default("Ny konversation")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     AiMessage[]

  @@index([organizationId])
  @@index([userId])
}

model AiMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // "user" | "assistant"
  content        String
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AiMemory {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  key            String
  value          String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, key])
  @@index([organizationId, userId])
}

// ─── Import Job ───────────────────────────────────────────────────────────────

model ImportJob {
  id             String          @id @default(uuid())
  organizationId String
  type           ImportJobType
  status         ImportJobStatus @default(PENDING)
  filename       String
  totalRows      Int             @default(0)
  processedRows  Int             @default(0)
  successRows    Int             @default(0)
  errorRows      Int             @default(0)
  errors         Json            @default("[]")
  createdById    String
  createdAt      DateTime        @default(now())
  completedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId])
}
