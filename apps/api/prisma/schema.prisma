// ─── Kontraktsmall-enums ─────────────────────────────────────────────────────

enum PetPolicy {
  ALLOWED
  REQUIRES_APPROVAL
  NOT_ALLOWED
}

enum IndexClauseType {
  NONE
  KPI // Konsumentprisindex (SCB)
  NEGOTIATED // Förhandlad hyra (bostad, 12:19 § JB)
  MARKET_RENT // Marknadshyra (lokal, 12:57–60 §§ JB)
}

// ─── Notification ────────────────────────────────────────────────────────────

enum NotificationType {
  INVOICE_OVERDUE
  INVOICE_PAID
  LEASE_EXPIRING
  LEASE_EXPIRED
  MAINTENANCE_NEW
  MAINTENANCE_UPDATED
  RENT_NOTICE_SENT
  RENT_NOTICE_OVERDUE
  INSPECTION_SCHEDULED
  SYSTEM
}

// ─── Platform / SaaS enums ────────────────────────────────────────────────────

enum PlatformPlan {
  TRIAL
  BASIC
  STANDARD
  PREMIUM
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum PlatformInvoiceStatus {
  PENDING
  PAID
  OVERDUE
  VOID
}

enum ErrorSeverity {
  CRITICAL
  ERROR
  WARNING
}

enum ErrorSource {
  API
  WEB
  PORTAL
  ADMIN
}

// Svenska företagsformer. Styr orgnummer-validering, BAS-kontoplan
// (eget kapital-serie), kontraktsformuleringar (firmatecknare vs ägare)
// och vilka skatteregister som visas på faktura.
enum CompanyForm {
  AB             // Aktiebolag — eget kapital 2080-serien
  ENSKILD_FIRMA  // Enskild näringsidkare — eget kapital 2010-serien
  HB             // Handelsbolag
  KB             // Kommanditbolag
  FORENING       // Ideell eller ekonomisk förening
  STIFTELSE      // Stiftelse
}

// ─── Organization (Tenant in multi-tenant context) ────────────────────────────

model Organization {
  id                   String  @id @default(uuid())
  name                 String
  orgNumber            String? @unique
  accountType          String  @default("COMPANY")
  // Juridisk företagsform. Sätts vid registrering och kan inte ändras
  // av användaren själv (kräver supportkontakt) — det skulle invalidera
  // hela kontoplanen och skattetexten på fakturor.
  companyForm          CompanyForm @default(AB)
  vatNumber            String?
  // F-skatt: obligatoriskt på faktura enligt 11 kap. 8 § ML att visa.
  // hasFSkatt = true ⇒ "Godkänd för F-skatt" tryckt på faktura-PDF.
  hasFSkatt            Boolean   @default(false)
  fSkattApprovedDate   DateTime?
  email                String
  phone                String?
  street               String
  city                 String
  postalCode           String
  country              String  @default("SE")
  logoStorageKey       String?
  logoStorageUrl       String?
  bankgiro             String?
  paymentTermsDays     Int     @default(30)
  invoiceColor         String?
  invoiceTemplate      InvoiceTemplate?
  morningReportEnabled Boolean @default(false)

  // ─── Påminnelse- och inkassoflöde ─────────────────────────────────────────
  // Lagstöd: Lag (1981:739) om ersättning för inkassokostnader — max 60 kr
  // för skriftlig påminnelse, 180 kr för inkassokrav. Vi tar bara ut
  // påminnelseavgiften — själva inkassoärendet hanteras externt.
  remindersEnabled       Boolean @default(true)
  reminderFeeSek         Decimal @default(60) @db.Decimal(10, 2)
  reminderFormalDay      Int     @default(14) // dagar efter förfall för formell påminnelse
  reminderCollectionDay  Int     @default(30) // dagar efter förfall innan markering "redo för inkasso"
  collectionAgencyName   String? // fritext: namn på fastighetsägarens valda inkassobolag

  // Platform / SaaS-fält
  plan               PlatformPlan       @default(TRIAL)
  status             OrganizationStatus @default(ACTIVE)
  trialEndsAt        DateTime?
  billingEmail       String?
  monthlyFee         Decimal            @default(0) @db.Decimal(10, 2)
  suspendedAt        DateTime?
  cancellationReason String?

  users              User[]
  properties         Property[]
  tenants            Tenant[]
  invoices           Invoice[]
  accounts           Account[]
  journalEntries     JournalEntry[]
  bankTransactions   BankTransaction[]
  documents          Document[]
  importJobs         ImportJob[]
  aiConversations    AiConversation[]
  aiMemories         AiMemory[]
  aiUsageLogs        AiUsageLog[]
  aiToolExecutions   AiToolExecution[]
  maintenanceTickets MaintenanceTicket[]
  rentNotices        RentNotice[]
  inspections        Inspection[]
  maintenancePlans   MaintenancePlan[]
  notifications      Notification[]
  newsPosts          NewsPost[]
  sentMessages       SentMessage[]
  platformInvoices   PlatformInvoice[]
  impersonationLogs  ImpersonationLog[]
  errorLogs          ErrorLog[]
  deposits           Deposit[]
  rentIncreases      RentIncrease[]
  customers          Customer[]
  closedPeriods      ClosedAccountingPeriod[]
  terminationRequests TerminationRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgNumber])
  @@index([status])
  @@index([plan])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  organizationId      String
  email               String    @unique
  // Nullable: vid invite skapas User utan lösenord. Lösenord sätts först
  // när inbjudan accepteras via /v1/auth/accept-invite. login() avvisar
  // användare där passwordHash är null (samma "Felaktiga inloggningsuppgifter"
  // som ett felaktigt lösenord — ingen enumeration).
  passwordHash        String?
  firstName           String
  lastName            String
  role                UserRole  @default(VIEWER)
  avatarUrl           String?
  isActive            Boolean   @default(true)
  mustChangePassword  Boolean   @default(false)
  lastLoginAt         DateTime?
  // Brute-force-skydd: räknar upp vid felaktigt lösenord, nollställs vid
  // lyckad inloggning. När loginAttempts ≥ 10 sätts lockedUntil 15 min
  // framåt och inga försök släpps förrän klockan passerat.
  loginAttempts       Int       @default(0)
  lockedUntil         DateTime?

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  invitations         UserInvitation[]
  journalEntries      JournalEntry[]
  closedPeriods       ClosedAccountingPeriod[]
  documents           Document[]
  importJobs          ImportJob[]
  aiConversations     AiConversation[]
  aiMemories          AiMemory[]
  aiUsageLogs         AiUsageLog[]
  aiToolExecutions    AiToolExecution[]
  notifications       Notification[]
  newsPosts           NewsPost[]
  sentMessages        SentMessage[]
  impersonationLogs   ImpersonationLog[]   @relation("ImpersonationTargetUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
}

// One-time-use tokens för glömt-lösenord-flödet. Cascade så att tokens
// försvinner om användaren raderas. usedAt sätts vid förbrukning för att
// förhindra återanvändning.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// One-time-use tokens för "bjud in användare"-flödet. När en OWNER/ADMIN
// bjuder in skapas både User (isActive=false) och en UserInvitation som
// pekar på det skapade kontot. Mottagaren accepterar via token.
model UserInvitation {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ─── Property (Fastighet) ─────────────────────────────────────────────────────

model Property {
  id                  String       @id @default(uuid())
  organizationId      String
  name                String
  propertyDesignation String
  type                PropertyType
  street              String
  city                String
  postalCode          String
  country             String       @default("SE")
  totalArea           Decimal      @db.Decimal(10, 2)
  yearBuilt           Int?

  // Information som genererade hyreskontrakt refererar till per fastighet —
  // hyresvärden fyller i en gång och slipper upprepa per kontrakt.
  fireSafetyNotes      String?
  commonAreasNotes     String?
  garbageDisposalRules String?

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  units              Unit[]
  documents          Document[]
  maintenanceTickets MaintenanceTicket[]
  inspections        Inspection[]
  maintenancePlans   MaintenancePlan[]
  newsPosts          NewsPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// ─── Unit (Lägenhet/Lokal) ────────────────────────────────────────────────────

model Unit {
  id          String     @id @default(uuid())
  propertyId  String
  name        String
  unitNumber  String
  type        UnitType
  status      UnitStatus @default(VACANT)
  area        Decimal    @db.Decimal(10, 2)
  floor       Int?
  rooms       Int?
  monthlyRent Decimal    @db.Decimal(10, 2)

  // Tilläggsutrustning som syns i kontrakts-PDF:n.
  hasBalcony         Boolean @default(false)
  hasStorage         Boolean @default(false)
  storageNumber      String?
  parkingSpaceNumber String?

  property           Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases             Lease[]
  documents          Document[]
  maintenanceTickets MaintenanceTicket[]
  inspections        Inspection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propertyId, unitNumber])
  @@index([propertyId])
  @@index([status])
}

// ─── Tenant (Hyresgäst) ───────────────────────────────────────────────────────

model Tenant {
  id             String     @id @default(uuid())
  organizationId String
  type           TenantType
  firstName      String?
  lastName       String?
  personalNumber String?
  companyName    String?
  orgNumber      String?
  contactPerson  String?
  email          String
  phone          String?
  street         String?
  city           String?
  postalCode     String?
  country        String?    @default("SE")

  ocrNumber String? @unique

  // ─── Portal-aktivering & lösenordsautentisering ─────────────────────────────
  // portalActivated sätts när hyresgästen genomfört aktiveringsflödet
  // (signerat kontraktet och valt lösenord). passwordHash = bcryptjs (12 rounds).
  // activationToken används både för första aktivering (skickas vid kontrakts-
  // signering) och vid återställning av glömt lösenord. unique för enkel lookup.
  portalActivated         Boolean   @default(false)
  portalActivatedAt       DateTime?
  passwordHash            String?
  activationToken         String?   @unique
  activationTokenExpiresAt DateTime?

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leases             Lease[]
  invoices           Invoice[]
  documents          Document[]
  signedDocuments    Document[]          @relation("DocumentSignedByTenant")
  maintenanceTickets MaintenanceTicket[]
  rentNotices        RentNotice[]
  inspections        Inspection[]
  magicLinks         TenantMagicLink[]
  sessions           TenantSession[]
  sentMessages       SentMessage[]
  deposits           Deposit[]
  aiConversations    AiTenantConversation[]
  aiUsageLogs        AiUsageLog[]
  aiToolExecutions   AiToolExecution[]
  terminationRequests TerminationRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
}

// ─── Customer (Externt kundregister, separerat från Tenant) ───────────────────
// För fakturering av icke-hyresgäster: städfirmor, mäklare, engångsleverantörer
// etc. Customer kan inte logga in i tenant-portalen och har inga kontrakt.

model Customer {
  id             String       @id @default(uuid())
  organizationId String
  type           CustomerType

  firstName      String?
  lastName       String?
  personalNumber String?
  companyName    String?
  orgNumber      String?
  contactPerson  String?

  email          String?
  phone          String?

  street         String?
  city           String?
  postalCode     String?
  country        String?      @default("SE")

  reference      String?
  notes          String?
  isActive       Boolean      @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

// ─── Lease (Hyresavtal) ───────────────────────────────────────────────────────

model Lease {
  id                   String      @id @default(uuid())
  organizationId       String
  unitId               String
  tenantId             String
  status               LeaseStatus @default(DRAFT)
  leaseType            LeaseType   @default(INDEFINITE)
  renewalPeriodMonths  Int? // Bara meningsfullt för FIXED_TERM
  startDate            DateTime    @db.Date
  endDate              DateTime?   @db.Date
  monthlyRent          Decimal     @db.Decimal(10, 2)
  depositAmount        Decimal     @db.Decimal(10, 2)
  noticePeriodMonths   Int         @default(3)
  // Behålls för bakåtkompatibilitet (gamla rader). Nya kontrakt sätter
  // indexClauseType — `indexClause` speglar då (type !== NONE).
  indexClause          Boolean     @default(false)
  signedAt             DateTime?
  terminatedAt         DateTime?
  terminationReason    String?

  // ── Vad ingår i hyran ────────────────────────────────────────────────────
  // Branschpraxis: bostäder har normalt värme, vatten, varmvatten och
  // tvättstuga inkluderade; hushållsel och internet betalar hyresgästen.
  includesHeating       Boolean @default(true)
  includesWater         Boolean @default(true)
  includesHotWater      Boolean @default(true)
  includesElectricity   Boolean @default(false)
  includesInternet      Boolean @default(false)
  includesCleaning      Boolean @default(false)
  includesParking       Boolean @default(false)
  includesStorage       Boolean @default(false)
  includesLaundry       Boolean @default(true)

  // ── Tilläggshyror utöver grundhyran ──────────────────────────────────────
  parkingFee Decimal? @db.Decimal(10, 2)
  storageFee Decimal? @db.Decimal(10, 2)
  garageFee  Decimal? @db.Decimal(10, 2)

  // ── Användningsändamål (kritiskt för lokal — styr besittningsskydd) ─────
  usagePurpose String?

  // ── Husdjur ─────────────────────────────────────────────────────────────
  petsAllowed       PetPolicy @default(REQUIRES_APPROVAL)
  petsApprovalNotes String?

  // ── Andrahandsuthyrning ─────────────────────────────────────────────────
  sublettingAllowed Boolean @default(false)

  // ── Indexklausul ────────────────────────────────────────────────────────
  // Allt valfritt — hyresvärden fyller i det som är aktuellt. Kontrolltyp
  // styr vilken text som visas i kontraktet (KPI/förhandlat/marknadshyra).
  indexClauseType     IndexClauseType @default(NONE)
  indexBaseYear       Int?
  indexAdjustmentDate String? // "01-01" eller "anniversary"
  indexMaxIncrease    Decimal? @db.Decimal(5, 2)
  indexMinIncrease    Decimal? @db.Decimal(5, 2)
  indexNotes          String?

  // ── Försäkring ──────────────────────────────────────────────────────────
  requiresHomeInsurance Boolean @default(true)

  unit                Unit                 @relation(fields: [unitId], references: [id])
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  invoices            Invoice[]
  documents           Document[]
  rentNotices         RentNotice[]
  inspections         Inspection[]
  deposit             Deposit?
  rentIncreases       RentIncrease[]
  terminationRequests TerminationRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // OBS: Det finns även ett partial unique index lease_unit_active_unique
  // ON "Lease" ("unitId") WHERE status = 'ACTIVE' — definierat i migration
  // 20260426120000_lease_active_unique. Prisma stöder inte WHERE-villkor i
  // schemat så det måste hållas i sync manuellt.

  @@index([organizationId])
  @@index([unitId])
  @@index([tenantId])
  @@index([status])
}

// ─── Invoice (Faktura) ────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  organizationId String
  invoiceNumber  String
  type           InvoiceType
  status         InvoiceStatus @default(DRAFT)
  tenantId       String?
  customerId     String?
  leaseId        String?
  subtotal       Decimal       @db.Decimal(10, 2)
  vatTotal       Decimal       @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  dueDate        DateTime      @db.Date
  issueDate      DateTime      @db.Date
  paidAt         DateTime?
  reference      String?
  ocrNumber      String?
  notes          String?

  // Tracking-token för e-postspårning (pixel + PDF-länk)
  // Genereras vid skapande, används aldrig om – en faktura, ett token.
  trackingToken String @unique @default(uuid())

  // Påminnelse- och inkassoflöde
  remindersPaused      Boolean   @default(false)
  remindersPausedAt    DateTime?
  remindersPausedReason String?
  sentToCollectionAt   DateTime?
  collectionExportKey  String? // R2-nyckel till senaste inkassounderlag

  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant           Tenant?            @relation(fields: [tenantId], references: [id])
  customer         Customer?          @relation(fields: [customerId], references: [id])
  lease            Lease?             @relation(fields: [leaseId], references: [id])
  lines            InvoiceLine[]
  events           InvoiceEvent[]
  bankTransactions BankTransaction[]
  deposit          Deposit?
  paymentReminders PaymentReminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([trackingToken])
  @@index([ocrNumber])
}

// ─── Invoice Event Log ────────────────────────────────────────────────────────
// Immutabel append-only tabell. Inga UPDATE, inga DELETE (utom via Cascade).
// Svensk bokföringslag kräver 7 års retention – soft-delete vid org-borttagning.

model InvoiceEvent {
  id        String           @id @default(uuid())
  invoiceId String
  type      InvoiceEventType

  // Aktör – vem/vad som utlöste händelsen
  actorType  EventActorType
  actorId    String? // userId eller null för system/webhook
  actorLabel String? // Denormaliserat: "Anna Svensson" / "System" / "Postmark"

  // Händelsespecifik data – flexibel JSON per händelsetyp
  // t.ex. { email, provider, messageId } för e-postleverans
  // t.ex. { amount, paymentMethod, reference } för betalning
  // t.ex. { previousStatus, newStatus } för statusövergång
  payload Json @default("{}")

  // E-postspårnings-metadata
  ipAddress String?
  userAgent String?

  // Immutabilitetsgaranti: ingen updatedAt
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Komposit-index för tidslinjequery (en faktura, sorterat på tid)
  @@index([invoiceId, createdAt])
  // Index för filtrering per händelsetyp
  @@index([invoiceId, type])
  // Index för global aktivitetsfeed
  @@index([createdAt])
}

model InvoiceLine {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(10, 4)
  unitPrice   Decimal @db.Decimal(10, 2)
  vatRate     Int
  total       Decimal @db.Decimal(10, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// Idempotency-spärr för påminnelseflödet. UNIQUE (invoiceId, type) garanterar
// att samma typ av påminnelse aldrig skickas två gånger för en faktura, även
// vid cron-restart eller race conditions.
model PaymentReminder {
  id             String              @id @default(uuid())
  invoiceId      String
  type           PaymentReminderType
  sentAt         DateTime            @default(now())
  feeAmount      Decimal             @default(0) @db.Decimal(10, 2)
  emailMessageId String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, type])
  @@index([invoiceId])
  @@index([sentAt])
}

// ─── Accounting ───────────────────────────────────────────────────────────────

model Account {
  id             String      @id @default(uuid())
  organizationId String
  number         Int
  name           String
  type           AccountType
  parentId       String?
  isActive       Boolean     @default(true)

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Account?           @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[]          @relation("AccountHierarchy")
  journalLines JournalEntryLine[]

  @@unique([organizationId, number])
  @@index([organizationId])
}

model JournalEntry {
  id             String             @id @default(uuid())
  organizationId String
  date           DateTime           @db.Date
  description    String
  reference      String?
  source         JournalEntrySource @default(MANUAL)
  sourceId       String?
  // Nullable för automatiska poster (t.ex. auto-match från bank-import) där
  // ingen användare är inloggad. Manuella poster har alltid en createdBy.
  createdById    String?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?              @relation(fields: [createdById], references: [id])
  lines        JournalEntryLine[]

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([date])
}

model JournalEntryLine {
  id             String   @id @default(uuid())
  journalEntryId String
  accountId      String
  debit          Decimal? @db.Decimal(10, 2)
  credit         Decimal? @db.Decimal(10, 2)
  description    String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

// Stänger en bokföringsperiod (månad+år) — efter close_period kan inga nya
// verifikat skapas med datum inom perioden. Append-only: en stängd period
// kan inte återöppnas via API (skulle kräva manuell DB-åtgärd).
model ClosedAccountingPeriod {
  id             String   @id @default(uuid())
  organizationId String
  month          Int
  year           Int
  closedAt       DateTime @default(now())
  closedById     String?
  summary        Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  closedBy     User?        @relation(fields: [closedById], references: [id])

  @@unique([organizationId, year, month])
  @@index([organizationId])
}

// ─── Bank Reconciliation (Bankavstämning) ─────────────────────────────────────

model BankTransaction {
  id             String                @id @default(uuid())
  organizationId String
  date           DateTime
  description    String
  amount         Decimal               @db.Decimal(12, 2)
  balance        Decimal?              @db.Decimal(12, 2)
  reference      String?
  rawOcr         String?
  status         BankTransactionStatus @default(UNMATCHED)
  invoiceId      String?
  matchedAt      DateTime?
  matchedBy      String?
  createdAt      DateTime              @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([invoiceId])
}

// ─── Document (Dokumentarkiv) ─────────────────────────────────────────────────

model Document {
  id             String           @id @default(uuid())
  organizationId String
  name           String
  description    String?
  storageKey     String
  storageUrl     String
  fileSize       Int
  mimeType       String
  category       DocumentCategory @default(OTHER)
  propertyId     String?
  unitId         String?
  leaseId        String?
  tenantId       String?
  uploadedById   String

  // ── Signering & versionskedja (används primärt för CONTRACT) ─────────────
  // contentHash är SHA-256 över PDF-bytena vid signeringstillfället. När
  // locked = true får storageKey/storageUrl ej ändras — ny version skapas
  // istället och refereras via previousVersionId.
  contentHash       String?
  signedAt          DateTime?
  signedByTenantId  String?
  signedFromIp      String?
  signedUserAgent   String?
  // Hyresgästens skrivna namnunderskrift vid signering. Lagras separat
  // från signedByTenant så att vi har två oberoende identitetsspår: vem
  // som autentiserade (FK) och vad de själva skrev (fritext).
  signatureName     String?
  locked            Boolean   @default(false)
  previousVersionId String?

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property         Property?    @relation(fields: [propertyId], references: [id])
  unit             Unit?        @relation(fields: [unitId], references: [id])
  lease            Lease?       @relation(fields: [leaseId], references: [id])
  tenant           Tenant?      @relation(fields: [tenantId], references: [id])
  uploadedBy       User         @relation(fields: [uploadedById], references: [id])
  signedByTenant   Tenant?      @relation("DocumentSignedByTenant", fields: [signedByTenantId], references: [id])
  previousVersion  Document?    @relation("DocumentVersionChain", fields: [previousVersionId], references: [id])
  newerVersions    Document[]   @relation("DocumentVersionChain")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([propertyId])
  @@index([unitId])
  @@index([leaseId])
  @@index([tenantId])
  @@index([previousVersionId])
}

// ─── AI Assistant ─────────────────────────────────────────────────────────────

model AiConversation {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  title          String   @default("Ny konversation")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     AiMessage[]

  @@index([organizationId])
  @@index([userId])
}

model AiMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String // "user" | "assistant"
  content        String
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum AiMemoryType {
  preference
  fact
  relationship
  convention
}

model AiMemory {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  key            String
  value          String       @db.Text
  type           AiMemoryType @default(fact)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, key])
  @@index([organizationId, userId])
}

// Spårar varje Anthropic-anrop med token-användning och uppskattad kostnad.
// Används av AiQuotaService för att stoppa orgs som överskrider månads-budget,
// samt för rapporter över AI-användning.
//
// Endera userId (fastighetsägar-AI) eller tenantId (hyresgäst-AI) är satt.
model AiUsageLog {
  id               String   @id @default(uuid())
  organizationId   String
  userId           String?
  tenantId         String?
  // 'chat' | 'stream' | 'analysis' | 'memory' | 'contract-scan' | 'inspection-analyze' | 'daily-insights' | 'tenant-chat'
  endpoint         String
  model            String
  inputTokens      Int      @default(0)
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  outputTokens     Int      @default(0)
  costUsd          Decimal  @db.Decimal(10, 6)
  costSek          Decimal  @db.Decimal(10, 4)
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenant       Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
}

// Audit-logg för varje AI-tool-exekvering. Krävs för GDPR och för att kunna
// utreda vad AI:n faktiskt gjorde i en organisations data.
//
// toolInput och toolResult lagras som JSON, men personnummer och
// organisationsnummer maskeras innan persistens (se ai-audit.service.ts).
//
// Endera userId (fastighetsägare) eller tenantId (hyresgäst) är satt.
model AiToolExecution {
  id                   String   @id @default(uuid())
  organizationId       String
  userId               String?
  tenantId             String?
  conversationId       String?
  toolName             String
  toolInput            Json
  toolResult           Json?
  success              Boolean
  errorMessage         String?
  durationMs           Int
  requiredConfirmation Boolean  @default(false)
  confirmedAt          DateTime?
  createdAt            DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([toolName])
}

// Hyresgäst-AI: separata tabeller från AiConversation/AiMessage för att hålla
// fastighetsägar- och hyresgäst-konversationer isolerade. Hyresgästen får
// ALDRIG se en konversation från en annan hyresgäst (cascade på Tenant.id
// säkerställer också att raderade hyresgäster städar sin chathistorik).
model AiTenantConversation {
  id        String   @id @default(uuid())
  tenantId  String
  title     String   @default("Ny konversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages AiTenantMessage[]

  @@index([tenantId, updatedAt])
}

model AiTenantMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String // "user" | "assistant"
  content        String
  createdAt      DateTime @default(now())

  conversation AiTenantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ─── Termination Request (uppsägningsbegäran från hyresgäst) ─────────────────

enum TerminationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model TerminationRequest {
  id               String                   @id @default(uuid())
  organizationId   String
  tenantId         String
  leaseId          String
  requestedEndDate DateTime
  reason           String?
  status           TerminationRequestStatus @default(PENDING)
  reviewedAt       DateTime?
  reviewedById     String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease        Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([tenantId])
  @@index([leaseId])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id             String           @id @default(uuid())
  organizationId String
  userId         String
  type           NotificationType
  title          String
  message        String
  link           String?
  read           Boolean          @default(false)
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([read])
  @@index([createdAt])
}

// ─── Import Job ───────────────────────────────────────────────────────────────

model ImportJob {
  id             String          @id @default(uuid())
  organizationId String
  type           ImportJobType
  status         ImportJobStatus @default(PENDING)
  filename       String
  totalRows      Int             @default(0)
  processedRows  Int             @default(0)
  successRows    Int             @default(0)
  errorRows      Int             @default(0)
  errors         Json            @default("[]")
  createdById    String
  createdAt      DateTime        @default(now())
  completedAt    DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId])
}

// ─── Maintenance (Underhåll) ──────────────────────────────────────────────────

model MaintenanceTicket {
  id             String  @id @default(uuid())
  ticketNumber   String
  organizationId String
  propertyId     String
  unitId         String?
  tenantId       String?
  reportedById   String?
  assignedToId   String?

  title       String
  description String              @db.Text
  category    MaintenanceCategory @default(OTHER)
  priority    MaintenancePriority @default(NORMAL)
  status      MaintenanceStatus   @default(NEW)

  estimatedCost Decimal? @db.Decimal(10, 2)
  actualCost    Decimal? @db.Decimal(10, 2)

  scheduledDate DateTime?
  completedAt   DateTime?

  tenantToken    String? @unique
  tenantNotified Boolean @default(false)

  images   MaintenanceImage[]
  comments MaintenanceComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id])
  unit         Unit?        @relation(fields: [unitId], references: [id])
  tenant       Tenant?      @relation(fields: [tenantId], references: [id])

  @@unique([organizationId, ticketNumber])
  @@index([organizationId])
  @@index([propertyId])
  @@index([status])
}

model MaintenanceImage {
  id         String   @id @default(uuid())
  ticketId   String
  filename   String
  storageKey String
  storageUrl String
  size       Int
  createdAt  DateTime @default(now())

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model MaintenanceComment {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String?
  content    String   @db.Text
  isInternal Boolean  @default(true)
  createdAt  DateTime @default(now())

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

// ─── Rent Notice (Hyresavi) ───────────────────────────────────────────────────

model RentNotice {
  id             String           @id @default(uuid())
  organizationId String
  tenantId       String
  leaseId        String
  noticeNumber   String           @unique
  ocrNumber      String
  month          Int
  year           Int
  amount         Decimal          @db.Decimal(10, 2)
  vatAmount      Decimal          @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal          @db.Decimal(10, 2)
  dueDate        DateTime
  paidAt         DateTime?
  paidAmount     Decimal?         @db.Decimal(10, 2)
  status         RentNoticeStatus @default(PENDING)
  sentAt         DateTime?
  sentTo         String?
  sendError      String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  lease        Lease        @relation(fields: [leaseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, tenantId, month, year])
  @@index([organizationId])
  @@index([status])
  @@index([dueDate])
}

// ─── Inspection (Besiktning) ──────────────────────────────────────────────────

model Inspection {
  id             String  @id @default(uuid())
  organizationId String
  propertyId     String
  unitId         String
  leaseId        String?
  tenantId       String?
  inspectedById  String

  type          InspectionType
  status        InspectionStatus @default(SCHEDULED)
  scheduledDate DateTime
  completedAt   DateTime?

  overallCondition String? @db.Text
  notes            String? @db.Text

  tenantSignature   String?
  landlordSignature String?
  signedAt          DateTime?

  items  InspectionItem[]
  images InspectionImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id])
  unit         Unit         @relation(fields: [unitId], references: [id])
  lease        Lease?       @relation(fields: [leaseId], references: [id])
  tenant       Tenant?      @relation(fields: [tenantId], references: [id])

  @@index([organizationId])
  @@index([unitId])
  @@index([status])
}

model InspectionItem {
  id           String                  @id @default(uuid())
  inspectionId String
  room         String
  item         String
  condition    InspectionItemCondition @default(GOOD)
  notes        String?
  repairCost   Decimal?                @db.Decimal(10, 2)

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
}

// ─── Maintenance Plan (Underhållsplan) ────────────────────────────────────────

model MaintenancePlan {
  id             String @id @default(uuid())
  organizationId String
  propertyId     String

  title       String
  description String?                 @db.Text
  category    MaintenancePlanCategory @default(OTHER)
  status      MaintenancePlanStatus   @default(PLANNED)

  plannedYear   Int
  estimatedCost Decimal  @db.Decimal(12, 2)
  actualCost    Decimal? @db.Decimal(12, 2)

  priority     Int  @default(2)
  interval     Int?
  lastDoneYear Int?

  notes       String?   @db.Text
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id])

  @@index([organizationId])
  @@index([propertyId])
  @@index([plannedYear])
}

model InspectionImage {
  id           String   @id @default(uuid())
  inspectionId String
  filename     String
  storageKey   String
  storageUrl   String
  caption      String?
  room         String?
  size         Int
  createdAt    DateTime @default(now())

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
}

// ─── Tenant Portal ────────────────────────────────────────────────────────────

model TenantMagicLink {
  id        String    @id @default(uuid())
  tenantId  String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tenantId])
}

model TenantSession {
  id        String   @id @default(uuid())
  tenantId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([token])
}

model NewsPost {
  id             String    @id @default(uuid())
  organizationId String
  title          String
  content        String    @db.Text
  publishedAt    DateTime?
  createdById    String
  targetAll      Boolean   @default(true)
  propertyId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property?    @relation(fields: [propertyId], references: [id])
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId])
}

// ─── Sent Messages (Meddelandehistorik) ──────────────────────────────────────

model SentMessage {
  id             String        @id @default(uuid())
  organizationId String
  tenantId       String?
  sentById       String
  subject        String
  content        String        @db.Text
  sentToAll      Boolean       @default(false)
  recipientCount Int           @default(1)
  successCount   Int           @default(0)
  failedCount    Int           @default(0)
  status         MessageStatus @default(SENT)
  errorLog       Json?
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant?      @relation(fields: [tenantId], references: [id])
  sentBy       User         @relation(fields: [sentById], references: [id])

  @@index([organizationId])
}

// ─── Platform (Super-admin SaaS) ──────────────────────────────────────────────

model PlatformUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  totpSecret   String?
  totpEnabled  Boolean   @default(false)
  lastLoginAt  DateTime?

  impersonationLogs ImpersonationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model PlatformInvoice {
  id             String                @id @default(uuid())
  organizationId String
  invoiceNumber  String                @unique
  amount         Decimal               @db.Decimal(10, 2)
  status         PlatformInvoiceStatus @default(PENDING)
  description    String?
  dueDate        DateTime
  paidAt         DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([dueDate])
}

model ImpersonationLog {
  id             String    @id @default(uuid())
  platformUserId String
  organizationId String
  targetUserId   String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  ipAddress      String?
  userAgent      String?
  reason         String?

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  targetUser   User         @relation("ImpersonationTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId])
  @@index([organizationId])
  @@index([targetUserId])
  @@index([startedAt])
}

model ErrorLog {
  id             String        @id @default(uuid())
  organizationId String?
  severity       ErrorSeverity
  source         ErrorSource
  message        String        @db.Text
  stack          String?       @db.Text
  context        Json          @default("{}")
  resolved       Boolean       @default(false)
  resolvedAt     DateTime?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId, severity, resolved])
  @@index([createdAt])
}

// ─── Mail engine — failed-job DLQ ─────────────────────────────────────────────
// När en mailjobb har uttömt sina retries sparas det här för manuell inspektion
// och eventuell replay. Append-only — behandlas som event log.

model FailedEmail {
  id        String   @id @default(uuid())
  jobId     String
  template  String
  to        String
  subject   String
  payload   Json
  error     String   @db.Text
  attempts  Int
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([template])
}

// ─── Deposit (Deposition) ─────────────────────────────────────────────────────

enum DepositStatus {
  PENDING            // Fakturerad, ej betald
  PAID               // Betald, förvaras
  REFUND_PENDING     // Kontrakt avslutat, väntar återbetalning
  REFUNDED           // Återbetald fullt
  PARTIALLY_REFUNDED // Återbetald med avdrag
  FORFEITED          // Förverkad (skador översteg deposition)
}

model Deposit {
  id             String        @id @default(uuid())
  organizationId String
  leaseId        String        @unique
  tenantId       String
  amount         Decimal       @db.Decimal(10, 2)
  status         DepositStatus @default(PENDING)
  invoiceId      String?       @unique
  paidAt         DateTime?
  refundedAt     DateTime?
  refundAmount   Decimal?      @db.Decimal(10, 2)
  deductions     Json?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lease        Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([tenantId])
}

// ─── RentIncrease (Hyreshöjning) ──────────────────────────────────────────────

enum RentIncreaseStatus {
  DRAFT       // Skapad men avisering ej skickad
  NOTICE_SENT // Avisering skickad till hyresgäst
  ACCEPTED    // Hyresgäst godkänt
  REJECTED    // Hyresgäst nekat
  WITHDRAWN   // Återkallad av hyresvärd
  APPLIED     // Den nya hyran har tillämpats på avtalet
}

model RentIncrease {
  id              String             @id @default(uuid())
  organizationId  String
  leaseId         String
  currentRent     Decimal            @db.Decimal(10, 2)
  newRent         Decimal             @db.Decimal(10, 2)
  increasePercent Decimal             @db.Decimal(6, 2)
  reason          String
  noticeDate      DateTime?
  effectiveDate   DateTime           @db.Date
  status          RentIncreaseStatus @default(DRAFT)
  respondedAt     DateTime?
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lease        Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([leaseId])
  @@index([status])
  @@index([effectiveDate])
}
