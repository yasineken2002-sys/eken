// Kravtrappa (inkasso-serien). HELT SKILD från betalnings-statusen ovan: en avi
// är OVERDUE i `status` (obetald, förfallen) men eskalerar separat genom
// kravtrappan här. Det gör att en avi kan bli PAID (status) mitt i trappan utan
// att vi tappar spåret av var den var. Steg:
//   NONE          → ingen åtgärd vidtagen (default)
//   REMINDED      → påminnelse utskickad + avgift bokförd (PR 2)
//   INKASSO_READY → fullständig dokumentation finns, redo för externt
//                   inkassobolag (PR 4). Eveno går ALDRIG längre än hit —
//                   förverkande/uppsägning/avhysning är hyresvärdens egen process.
//   WRITTEN_OFF   → konstaterad kundförlust bokförd 1515→6352 (PR 5)
// PR 1 introducerar bara fältet (default NONE) — inget läser eller eskalerar det än.
enum RentCollectionStage {
  NONE
  REMINDED
  INKASSO_READY
  WRITTEN_OFF
}

