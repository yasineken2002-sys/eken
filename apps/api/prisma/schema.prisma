  PDF_VIEWED
  // Betalning
  PAYMENT_RECEIVED
  PAYMENT_PARTIAL
  PAYMENT_REVERSED
  // Förfallen-flöde
  OVERDUE
  REMINDER_SENT
  DEBT_COLLECTION
  // Korrigeringar
  VOIDED
  CREDIT_NOTE_CREATED
  // Administrativt
  NOTE_ADDED
  VIEWED_BY_USER
