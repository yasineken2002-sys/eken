  CANCELLED
}

enum MaintenancePlanCategory {
  ROOF
  FACADE
  WINDOWS
  PLUMBING
  ELECTRICAL
  HEATING
  ELEVATOR
  COMMON_AREAS
  PAINTING
  FLOORING
  OTHER
}

enum DocumentCategory {
  CONTRACT
  INSPECTION
  DRAWING
  PHOTO
  INVOICE
  INSURANCE
  // Kontraktsbilagor — bifogas hyreskontraktets sista sida som
  // länkad bilageförteckning. ENERGY_DECLARATION krävs enligt lag
  // (2006:985), HOUSE_RULES bifogas vid behov, INSPECTION_PROTOCOL
  // är tillträdes-/avflyttningsbesiktning.
  ENERGY_DECLARATION
  HOUSE_RULES
  INSPECTION_PROTOCOL
  OTHER
}

