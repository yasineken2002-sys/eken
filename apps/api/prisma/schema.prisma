// ─── Organization (Tenant in multi-tenant context) ────────────────────────────

model Organization {
  id                   String  @id @default(uuid())
  name                 String
  orgNumber            String? @unique
  // Kort, läsbart och plattformsglobalt kundnummer (K-100001, K-100002 …) —
  // en stabil, permanent identifierare att söka/slå upp på i admin-portalen,
  // till skillnad från det interna UUID:t och det optionella orgNumber (som
  // saknas för privatpersoner/trial). Nullable i detta steg så befintliga
  // rader inte bryter migrationen; backfill:as i createdAt-ordning i samma
  // migration och allokeras vid org-skapande via CustomerNumberService.
  // Görs NOT NULL i en separat PR efter prod-verifierad backfill.
  customerNumber       String? @unique
  accountType          String  @default("COMPANY")
  // Juridisk företagsform. Sätts vid registrering och kan inte ändras
  // av användaren själv (kräver supportkontakt) — det skulle invalidera
  // hela kontoplanen och skattetexten på fakturor.
  companyForm          CompanyForm @default(AB)
  // Räkenskapsårets startmånad (1–12). 1 = kalenderår (BFL 3 kap 1 §, default
  // och tvingande för enskild firma/HB). AB får ha brutet räkenskapsår — t.ex.
  // 5 = maj–april. Styr vilket räkenskapsår en verifikation hör till, och
  // därmed verifikationsnummerserien (se VerifikationsnummerService).
  fiscalYearStartMonth Int @default(1)
  vatNumber            String?
  // F-skatt: obligatoriskt på faktura enligt 11 kap. 8 § ML att visa.
  // hasFSkatt = true ⇒ "Godkänd för F-skatt" tryckt på faktura-PDF.
  hasFSkatt            Boolean   @default(false)
  fSkattApprovedDate   DateTime?
  email                String
  phone                String?
  street               String
  city                 String
  postalCode           String
  country              String  @default("SE")
  logoStorageKey       String?
  logoStorageUrl       String?
  bankgiro             String?
  paymentTermsDays     Int     @default(30)
  invoiceColor         String?
  invoiceTemplate      InvoiceTemplate?

  // ── PDF-/dokumentvarumärke (Steg 3, PR 1 — endast datafundament) ──────────
  // INGEN PDF/e-post läser dessa fält ännu — de kopplas in i senare PR:er.
  // brandFont: kontrollerad enum (se BrandFont). Default SYSTEM_SANS =
  // nuvarande hårdkodade typsnitt → befintliga orgs renderar oförändrat.
  // brandSecondaryColor: sekundär/accentfärg (hex #RRGGBB), nullable. NULL →
  // härleds från invoiceColor (primär) / DEFAULT_BRAND_COLOR vid inkoppling.
  brandFont            BrandFont @default(SYSTEM_SANS)
  brandSecondaryColor  String?

  morningReportEnabled Boolean @default(false)

  // Intern kontrollgräns (COSO) för PDF-bankavstämning: rader vars belopp
  // överstiger detta avvisas och loggas vid AI-tolkning/confirm (flagga, ej
  // hårt stopp av importen). Default 5 MSEK — en enskild hyresinbetalning
  // överstiger praktiskt taget aldrig detta. Höjs per org vid legitima stora
  // kommersiella transaktioner. Absolut tak är MAX_TX_AMOUNT (50 MSEK) i koden.
  maxBankTxAmount      Decimal @default(5000000) @db.Decimal(14, 2)

  // Kostnadstak för batch-kontraktsskanning (skydd mot oförutsedd AI-kostnad).
  // Speglar maxBankTxAmount-precedensen: per-org konfigurerbar, med ett absolut
  // tak i koden. maxContractBatchFiles = max antal PDF:er per batch (default 50,
  // absolut tak MAX_BATCH_FILES_ABSOLUTE). maxContractBatchCostSek = tak på den
  // ESTIMERADE kostnaden som beräknas innan batchen körs; överskrids det avvisas
  // batchen direkt (inget enqueueas).
  maxContractBatchFiles   Int     @default(50)
  maxContractBatchCostSek Decimal @default(50) @db.Decimal(10, 2)

  // ── Hyresavi-inställningar ────────────────────────────────────────────────
  // Antal dagar före tillträdesdag som deposition + första hyresavi förfaller.
  // Standard 7 dagar — Hyresgästföreningens rekommendation. Hyresvärden kan
  // justera (5/7/14) i organisationsinställningarna.
  daysBeforeMoveInForFirstPayment Int @default(7)

  // ─── Påminnelse- och inkassoflöde ─────────────────────────────────────────
  // Lagstöd: Lag (1981:739) om ersättning för inkassokostnader — max 60 kr
  // för skriftlig påminnelse, 180 kr för inkassokrav. Vi tar bara ut
  // påminnelseavgiften — själva inkassoärendet hanteras externt.
  remindersEnabled       Boolean @default(true)
  reminderFeeSek         Decimal @default(60) @db.Decimal(10, 2)
  reminderFormalDay      Int     @default(14) // dagar efter förfall för formell påminnelse
  reminderCollectionDay  Int     @default(30) // dagar efter förfall innan markering "redo för inkasso"
  collectionAgencyName   String? // fritext: namn på fastighetsägarens valda inkassobolag

  // ── Hyres-specifik kravtrappa (inkasso-serien) ────────────────────────────
  // SKILD från reminderFormalDay/reminderCollectionDay ovan, som styr det äldre
  // faktura-flödet (dag 14/30). Juristens fastställda regel för HYRA är en egen
  // tidslinje och får aldrig hårdkodas — den är konfigurerbar per fastighetsägare:
  //   • rentReminderDay = dagar efter förfallodag innan påminnelse skickas (dag 7).
  //   • rentInkassoDaysAfterReminder = dagar efter påminnelsen innan ärendet blir
  //     inkasso-ready (14). Avgiften återanvänder reminderFeeSek (60 kr, momsfri).
  // Läses av PR 2 (påminnelse) resp. PR 4 (inkasso-ready). PR 1 sätter bara default.
  rentReminderDay              Int @default(7)
  rentInkassoDaysAfterReminder Int @default(14)

  // ── Bankavstämnings-härdning PR 4 (B): betalningsdatans färskhet ───────────
  // DATAKÄLLS-AGNOSTISKT: datumet t.o.m. vilket vi litar på att betalningsdata är
  // KOMPLETT. Idag matas det av bankimporterna (CSV/BgMax/PDF) — coverage = senaste
  // importerade transaktionsdatum resp. PDF-periodens slut, monotont framåt. En
  // framtida bank-aggregator (Tink/Enable Banking) matar SAMMA fält med sin
  // lastSyncedAt utan omskrivning. NULL = ingen betalningsdata ingestad ännu →
  // färskhetsgrinden engagerar INTE (manuellt avstämmande org bricks aldrig); den
  // slår till FÖRST när data väl börjat matas och sedan blir gammal.
  paymentDataThrough        DateTime? @db.Date
  // Tröskel i dagar: är paymentDataThrough äldre än så → STALE → pausa kravtrappans
  // pengamodifierande/inkasso-framflyttande eskalering + larma. Konfigurerbar per org.
  paymentDataStaleDays      Int       @default(3)
  // Idempotensmarkör för stale-larmet: sätts när larmet skickats, nollställs när
  // FÄRSK data åter matas (recordPaymentDataThrough). Säkrar EN notis per stale-
  // period — inte per cron-körning.
  paymentDataStaleAlertedAt DateTime?

  // Platform / SaaS-fält
  // subscriptionPlan styr maxObjects + AI-anropstak; status styr åtkomst.
  // PLAN_LIMITS i @eken/shared mappar plan → siffror.
  subscriptionPlan   SubscriptionPlan @default(TRIAL)
  status             OrgStatus        @default(TRIAL)
  planStartedAt      DateTime         @default(now())
  trialEndsAt        DateTime?
  billingEmail       String?
  // Månadsavgift exkl moms, snapshotat när plan väljs. Vi behåller en kopia
  // på Organization istället för att enbart lita på PLAN_LIMITS så att
  // historiska planbyten kan reproduceras (om vi någonsin justerar prislistan).
  planMonthlyFee     Decimal          @default(0) @db.Decimal(10, 2)
  // Köpta extra AI-credits (1 kr/anrop exkl moms). Dras automatiskt
  // när organisationen passerar plan-taket på manuella anrop.
  aiCreditsBalance   Int              @default(0)
  suspendedAt        DateTime?
  cancellationReason String?
  // Sista trial-påminnelsen som skickats, i kvarvarande dagar (7/3/1).
  // Idempotensnyckel för sendTrialEndingReminders så att samma steg inte
  // mailas två gånger.
  lastTrialReminderDays Int?
  // Hård spärr mot plattformsfakturering. Sätts manuellt på test-,
  // intern- och friends&family-konton. Respekteras i ALLA
  // genereringsvägar (månadscron, backfill, manuell trigger).
  excludeFromBilling Boolean @default(false)

  // ─── Acceptans av plattformens juridiska dokument ─────────────────────
  // Org-nivå-acceptans används av re-acceptance-modalen: när
  // CURRENT_TERMS_VERSION i @eken/shared höjs visas modalen för alla
  // OWNER/ADMIN-användare i organisationen tills de bekräftat. Denna
  // koll är separat från User.acceptedTermsAt — användarens egen
  // acceptans gäller vid signup, medan org-acceptansen rör senare
  // versionsbyten som binder hela bolaget.
  termsAcceptedAt    DateTime?
  termsVersion       String?

  users              User[]
  properties         Property[]
  tenants            Tenant[]
  invoices           Invoice[]
  accounts           Account[]
  journalEntries     JournalEntry[]
  bankTransactions   BankTransaction[]
  bankStatementImports BankStatementImport[]
  bankConsents       BankConsent[]
  contractImportBatches ContractImportBatch[]
  documents          Document[]
  importJobs         ImportJob[]
  aiConversations    AiConversation[]
  aiMemories         AiMemory[]
  aiUsageLogs        AiUsageLog[]
  aiToolExecutions   AiToolExecution[]
  maintenanceTickets MaintenanceTicket[]
  rentNotices        RentNotice[]
  inspections        Inspection[]
  maintenancePlans   MaintenancePlan[]
  notifications      Notification[]
  newsPosts          NewsPost[]
  sentMessages       SentMessage[]
  platformInvoices   PlatformInvoice[]
  impersonationLogs  ImpersonationLog[]
  errorLogs          ErrorLog[]
  contractNumberSequences ContractNumberSequence[]
  maintenanceTicketSequence MaintenanceTicketSequence?
  journalEntrySequences JournalEntrySequence[]
  invoiceNumberSequence InvoiceNumberSequence?
  deposits           Deposit[]
  rentIncreases      RentIncrease[]
  customers          Customer[]
  closedPeriods      ClosedAccountingPeriod[]
  terminationRequests TerminationRequest[]
  keyHandovers       KeyHandover[]
  meters             Meter[]
  meterReadings      MeterReading[]
  consumptionTariffs ConsumptionTariff[]
  consumptionCharges ConsumptionCharge[]
  miscCharges        MiscCharge[]
  signingRequests    SigningRequest[]
