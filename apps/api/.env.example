NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://eken:eken@localhost:5432/eken_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_REFRESH_SECRET=change-this-to-another-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Platform / Super-admin
PLATFORM_JWT_SECRET=change-me-to-a-separate-long-random-string
PLATFORM_JWT_REFRESH_SECRET=change-me-to-another-separate-long-random-string
PLATFORM_JWT_ACCESS_EXPIRES_IN=1h
PLATFORM_JWT_REFRESH_EXPIRES_IN=30d
PLATFORM_SEED_EMAIL=yasin@eken.se
PLATFORM_SEED_FIRST_NAME=Yasin
PLATFORM_SEED_LAST_NAME=Eken

# App
APP_URL=http://localhost:5173
ADMIN_URL=http://localhost:5175
API_URL=http://localhost:3000
PORTAL_URL=http://localhost:5174

# CORS (comma-separated origins, supports wildcards e.g. https://*.example.com)
# Leave empty in development to use defaults (localhost:5173, localhost:5174)
ALLOWED_ORIGINS=https://your-admin-domain.com,https://your-portal-domain.com

# SMTP (e-post)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM="Eken Fastigheter <no-reply@eken.se>"

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# AI (Contract scanner)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Cloudflare R2 (dokumentlagring – S3-kompatibelt)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=eken-documents
