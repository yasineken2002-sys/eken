NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://eken:eken@localhost:5432/eken_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_REFRESH_SECRET=change-this-to-another-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Platform / Super-admin
PLATFORM_JWT_SECRET=change-me-to-a-separate-long-random-string
PLATFORM_JWT_REFRESH_SECRET=change-me-to-another-separate-long-random-string
PLATFORM_JWT_ACCESS_EXPIRES_IN=1h
PLATFORM_JWT_REFRESH_EXPIRES_IN=30d
PLATFORM_SEED_EMAIL=yasin@eken.se
PLATFORM_SEED_FIRST_NAME=Yasin
PLATFORM_SEED_LAST_NAME=Eken

# App
APP_URL=http://localhost:5173
# WEB_URL används för reset-/inbjudningslänkar i mejl. I prod: sätt till kundens
# publika webb-URL (annars localhost-länkar som mottagaren aldrig kan öppna).
WEB_URL=http://localhost:5173
ADMIN_URL=http://localhost:5175
API_URL=http://localhost:3000
PORTAL_URL=http://localhost:5174

# CORS (comma-separated origins, supports wildcards e.g. https://*.example.com)
# Leave empty in development to use defaults (localhost:5173, localhost:5174)
ALLOWED_ORIGINS=https://your-admin-domain.com,https://your-portal-domain.com

# Plattformsfakturering (autonom billing)
# AUTO_SEND_PLATFORM_INVOICES: 'true' (default) = månadscron/backfill mailar
#   fakturan direkt efter att den skapats. 'false' = skapas bara som DRAFT
#   (operatören skickar manuellt). VIKTIGT: sätt 'false' i Railway-prod
#   initialt, verifiera DRAFT-skapande via admin-UI, flippa sedan till 'true'.
AUTO_SEND_PLATFORM_INVOICES=true
# TRIAL_GRACE_PERIOD_DAYS: extra dagar efter trialEndsAt innan en utgången
#   trial konverteras (plan vald) eller pausas (ingen plan). Default 3.
TRIAL_GRACE_PERIOD_DAYS=3

# E-post (Resend) — kräver verifierad domän i Resend-dashboarden
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM="Eveno Fastigheter <noreply@eveno.se>"
# Webhook-signeringshemlighet (Svix) — Resend-dashboard → Webhooks → Signing
# Secret. Verifierar POST /v1/webhooks/resend. Utan den avvisas alla webhooks.
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# AI (Contract scanner)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Voyage AI – embeddings för juridik-RAG:ens semantiska sökning (Etapp 3).
# Används av knowledge:embed-scriptet och query-embedding i retrieval.
VOYAGE_API_KEY=pa-your-voyage-key-here

# Cloudflare R2 (dokumentlagring – S3-kompatibelt)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=eken-documents

# Sentry (error tracking) — lämna tom i dev så Sentry inaktiveras helt
SENTRY_DSN=
# Sätts av deploy-scriptet (Railway) till git commit-sha så releases kan
# kopplas till Sentry-incidenter. Lokalt kan den lämnas tom.
SENTRY_RELEASE=

# PSD2-bankkoppling (P2) — INAKTIV som standard. Aktiveras först i P3 när en skarp
# aggregator-adapter (Enable Banking/Tink) + avtal/nycklar finns. Sätt PSD2_ENABLED=true
# UTAN PSD2_TOKEN_KEY → appen vägrar starta (fail-fast, avsiktligt).
PSD2_ENABLED=false
# 64 hex-tecken (32 byte) — AES-256-GCM-nyckel för kryptering av bank-tokens at-rest.
# Egen nyckel, separerad från SIGNING_PII_KEY. Generera: openssl rand -hex 32
PSD2_TOKEN_KEY=
# Bankens redirect-mål efter SCA (vår publika callback-URL).
PSD2_CALLBACK_URL=http://localhost:3000/v1/reconciliation/psd2/callback
# Frontend-URL dit callbacken skickar tillbaka användaren efter samtycke.
PSD2_APP_RETURN_URL=http://localhost:5173/reconciliation/settings

# E-signering (S1/S2) — INAKTIV som standard. Aktiveras först i S3 när en skarp
# signeringsadapter (Scrive/Assently) + avtal/nycklar finns. Sätt SIGNING_ENABLED=true
# UTAN nycklarna nedan → appen vägrar starta (fail-fast, avsiktligt).
SIGNING_ENABLED=false
# 64 hex-tecken (32 byte) — AES-256-GCM-nyckel för kryptering av personnummer at-rest.
# Egen nyckel, separerad från PSD2_TOKEN_KEY. Generera: openssl rand -hex 32
SIGNING_PII_KEY=
# HMAC-pepper (≥16 tecken) för blind-index på personnummer. Generera: openssl rand -hex 16
SIGNING_PII_PEPPER=

# Databasbackup (pg_dump → R2) — INAKTIV som standard. I prod MÅSTE en dedikerad
# R2-token + bucket användas (delar inte huvud-R2-nycklarna) annars blockeras backupen.
BACKUP_ENABLED=false
# Antal dagar backuper behålls innan gallring. Default 30.
BACKUP_RETENTION_DAYS=30
# Dedikerade backup-R2-kredentialer. Faller tillbaka till huvud-R2-nycklarna i dev,
# men i prod krävs egna (annars fail-closed no-op + error-logg).
R2_BACKUP_ACCOUNT_ID=
R2_BACKUP_ACCESS_KEY_ID=
R2_BACKUP_SECRET_ACCESS_KEY=
R2_BACKUP_BUCKET=
