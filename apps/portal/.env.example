# apps/portal — Vite env vars
# Obs: endast variabler med VITE_-prefix exponeras till klientkoden.

# URL till apps/api. Lämna tom i dev — Vite-proxyn rewritar /api → :3000
# automatiskt. Sätt i produktion där API:t inte ligger på samma domän.
VITE_API_URL=

# Tenant-id för dev-impersonation av portal — bara för utvecklingsmiljö.
VITE_DEV_TENANT_ID=

# Sentry (error tracking) — lämna tom i dev så Sentry inaktiveras helt
VITE_SENTRY_DSN=
# Sätts av build-skriptet till git commit-sha så releases kan kopplas
# till Sentry-incidenter. Lokalt kan den lämnas tom.
VITE_GIT_COMMIT_SHA=
